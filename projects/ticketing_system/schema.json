{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {"type": "string"},
    "title": {"type": "string"},
    "description": {"type": "string"},
    "actionable_items": {"type": "array", "items": {"type": "string"}},
    "blurbs": {"type": "array", "items": {"type": "string"}},
    "warm_intro_cues": {"type": "array", "items": {"type": "string"}},
    "meeting_metadata": {
      "type": "object",
      "properties": {
        "participants": {"type": "array", "items": {"type": "string"}},
        "roles": {"type": "object", "additionalProperties": {"type": "string"}},
        "deliverables": {"type": "array", "items": {"type": "string"}}
      }
    },
    "priority": {"type": "string", "enum": ["low", "medium", "high"]},
    "output_type": {"type": "string"},
    "review_flags": {"type": "array", "items": {"type": "string"}},
    "version": {"type": "string"},
    "related_tickets": {"type": "array", "items": {"type": "string"}},

    "contextual_enrichment": {"type": "string"},
    "llm_instructions": {"type": "string"},
    "categories": {"type": "array", "items": {"type": "string"}},
    "context_summary": {"type": "string"},
    "content_creation_hints": {"type": "array", "items": {"type": "string"}},

    "assignee": {"type": "string"},
    "status": {"type": "string", "enum": ["open", "in_progress", "review", "completed"]},
    "due_date": {"type": "string"},
    "progress": {"type": "number", "minimum": 0, "maximum": 100},
    "quality_score": {"type": "number", "minimum": 0, "maximum": 10},
    "feedback": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["id", "title"]
}