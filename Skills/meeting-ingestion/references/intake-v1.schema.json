{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zo.computer/schemas/intake-v1",
  "title": "Unified Intake Manifest v1",
  "description": "Common envelope schema for all transcript sources landing in Personal/Inbox/. Extended by downstream pipelines (manifest-v3 for meetings, reflection manifest for reflections) after routing.",
  "type": "object",
  "required": ["$schema", "item_id", "content_type", "status", "source", "timestamps"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "intake-v1",
      "description": "Schema version identifier"
    },
    "item_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}_[A-Za-z0-9_-]+$",
      "description": "Item identifier in YYYY-MM-DD_Slug format"
    },
    "content_type": {
      "type": "string",
      "enum": ["meeting", "reflection", "unclassified"],
      "description": "Content type — starts as unclassified, set by classifier"
    },
    "status": {
      "type": "string",
      "enum": ["landed", "classified", "heed_scanned", "routed"],
      "description": "Current intake pipeline status"
    },
    "source": {
      "type": "object",
      "required": ["type", "adapter", "adapter_version", "original_filename", "ingested_at"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["pocket", "fireflies", "fathom", "manual"],
          "description": "Source system"
        },
        "adapter": {
          "type": "string",
          "description": "Adapter identifier, e.g. pocket_v1, fireflies_v1"
        },
        "adapter_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of the adapter"
        },
        "original_filename": {
          "type": "string",
          "description": "Original filename from source"
        },
        "raw_id": {
          "type": ["string", "null"],
          "description": "Source-specific ID (recording ID, Drive file ID, etc.)"
        },
        "ingested_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the source adapter processed the item"
        }
      },
      "additionalProperties": false
    },
    "classification": {
      "type": ["object", "null"],
      "properties": {
        "content_type": {
          "type": "string",
          "enum": ["meeting", "reflection"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "method": {
          "type": "string",
          "enum": ["speaker_count", "source_default", "manual", "metadata"]
        },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "speaker_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "duration_seconds": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "content": {
      "type": "object",
      "required": ["date"],
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Recording date"
        },
        "title": {
          "type": ["string", "null"],
          "description": "Populated after routing by downstream pipeline with semantic memory"
        },
        "summary": {
          "type": ["string", "null"],
          "description": "Populated after routing by downstream pipeline with semantic memory"
        },
        "word_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}$",
          "default": "en",
          "description": "ISO 639-1 language code"
        }
      },
      "additionalProperties": false
    },
    "zo_take_heed": {
      "type": ["object", "null"],
      "properties": {
        "scanned": {
          "type": "boolean"
        },
        "triggers_found": {
          "type": "integer",
          "minimum": 0
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/zth_action" }
        }
      },
      "additionalProperties": false
    },
    "timestamps": {
      "type": "object",
      "required": ["landed_at"],
      "properties": {
        "landed_at": {
          "type": "string",
          "format": "date-time"
        },
        "classified_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "heed_scanned_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "routed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": ["object", "null"],
      "properties": {
        "conversation_id": {
          "type": ["string", "null"]
        },
        "agent_id": {
          "type": ["string", "null"]
        },
        "build": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true,
  "$defs": {
    "zth_action": {
      "type": "object",
      "required": ["id", "raw_cue", "instruction", "task_type", "execution_policy", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ZTH-\\d{8}-\\d{3}$",
          "description": "Unique trigger ID in ZTH-YYYYMMDD-NNN format"
        },
        "raw_cue": {
          "type": "string",
          "description": "Verbatim transcript excerpt containing the trigger"
        },
        "instruction": {
          "type": "string",
          "description": "Extracted instruction from the trigger"
        },
        "task_type": {
          "type": "string",
          "enum": [
            "directive",
            "blurb",
            "follow_up_email",
            "warm_intro",
            "research",
            "list_add",
            "deal_add",
            "deal_update",
            "crm_contact",
            "intro_lead",
            "custom"
          ]
        },
        "execution_policy": {
          "type": "string",
          "enum": ["auto_execute", "queue", "inline"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "executed", "failed", "queued"]
        },
        "executed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "execution_result": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  }
}
