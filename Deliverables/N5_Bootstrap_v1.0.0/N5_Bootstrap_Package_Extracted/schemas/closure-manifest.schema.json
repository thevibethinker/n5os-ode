{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n5.local/schemas/closure-manifest.schema.json",
  "title": "N5 Closure Manifest Entry",
  "description": "Schema for conversation closure tracking records",
  "type": "object",
  "required": [
    "closure_num",
    "timestamp",
    "event_range",
    "archive_path"
  ],
  "additionalProperties": false,
  "properties": {
    "closure_num": {
      "type": "integer",
      "minimum": 1,
      "description": "Sequential closure number (1, 2, 3...)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last user message before closure"
    },
    "event_range": {
      "type": "string",
      "pattern": "^[0-9]+-[0-9]+$",
      "description": "Event range covered by this closure (e.g., '1-45')"
    },
    "archive_path": {
      "type": "string",
      "description": "Relative path from workspace to closure directory"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief summary of work completed in this closure"
    },
    "artifacts_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of artifacts archived in this closure"
    }
  },
  "examples": [
    {
      "closure_num": 1,
      "timestamp": "2025-10-16T10:30:00Z",
      "event_range": "1-45",
      "archive_path": "Documents/Archive/2025-10-16-Feature-Implementation/closure-1",
      "summary": "Initial feature implementation with tests",
      "artifacts_count": 12
    },
    {
      "closure_num": 2,
      "timestamp": "2025-10-16T14:15:00Z",
      "event_range": "46-50",
      "archive_path": "Documents/Archive/2025-10-16-Feature-Implementation/closure-2",
      "summary": "Documentation updates and bug fixes",
      "artifacts_count": 3
    }
  ]
}
