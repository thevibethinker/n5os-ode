{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Meeting Metadata Schema",
  "description": "Structured metadata for processed meeting intelligence (v2.0)",
  "type": "object",
  "required": [
    "meeting_id",
    "date",
    "meeting_type",
    "stakeholder_primary",
    "processing"
  ],
  "properties": {
    "meeting_id": {
      "type": "string",
      "description": "Unique 6-character identifier",
      "pattern": "^[a-z0-9]{6}$"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Meeting date in YYYY-MM-DD format"
    },
    "time": {
      "type": "string",
      "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$",
      "description": "Meeting time in HH:MM format (24-hour)"
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone identifier",
      "default": "America/New_York"
    },
    "meeting_type": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "sales",
          "community_partnerships",
          "coaching",
          "networking",
          "fundraising"
        ]
      },
      "minItems": 1,
      "description": "Meeting type(s) - supports multi-classification"
    },
    "stakeholder_classification": {
      "type": "string",
      "enum": ["internal", "external"],
      "description": "Meeting classification based on participant domains. Internal if ALL participants are @mycareerspan.com or @theapply.ai, External if ANY participant is from external domain"
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "classification": {
            "type": "string",
            "enum": ["internal", "external"]
          }
        }
      },
      "description": "Detailed participant information with classification"
    },
    "stakeholder_primary": {
      "type": "string",
      "description": "Primary stakeholder identifier (lowercase, hyphenated)"
    },
    "stakeholders_all": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "All external stakeholders in meeting"
    },
    "stakeholder_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "customer_founder",
          "customer_hiring_manager",
          "customer_recruiting_lead",
          "customer_channel_partner",
          "community_manager",
          "candidate_job_seeker",
          "investor",
          "vc"
        ]
      },
      "description": "Stakeholder type classifications"
    },
    "organization": {
      "type": "string",
      "description": "Organization/company name if applicable"
    },
    "participants_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Total number of participants (including you)"
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 1,
      "description": "Meeting duration in minutes"
    },
    "previous_meetings_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of previous meetings with this stakeholder"
    },
    "previous_meeting_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Meeting IDs of previous meetings with stakeholder"
    },
    "email_history_found": {
      "type": "boolean",
      "description": "Whether email history was successfully retrieved"
    },
    "email_thread_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of emails in thread with stakeholder"
    },
    "intelligence": {
      "type": "object",
      "description": "Extracted intelligence metrics",
      "properties": {
        "buying_signal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "description": "Buying signal strength (sales meetings only)"
        },
        "risks_count": {
          "type": "integer",
          "minimum": 0
        },
        "opportunities_count": {
          "type": "integer",
          "minimum": 0
        },
        "warm_intros_count": {
          "type": "integer",
          "minimum": 0
        },
        "decisions_count": {
          "type": "integer",
          "minimum": 0
        },
        "action_items_count": {
          "type": "integer",
          "minimum": 0
        },
        "insights_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "processing": {
      "type": "object",
      "required": ["version", "mode", "timestamp"],
      "properties": {
        "version": {
          "type": "string",
          "description": "meeting-process command version"
        },
        "mode": {
          "type": "string",
          "enum": ["full", "essential", "quick"],
          "description": "Processing mode used"
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Processing time in seconds"
        },
        "blocks_generated": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of output blocks generated"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Processing completion timestamp (ISO 8601)"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "component": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": ["warning", "error", "critical"]
              }
            }
          },
          "description": "Processing errors encountered"
        }
      }
    },
    "transcript_source": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["google_drive", "local_file", "email_attachment"]
        },
        "identifier": {
          "type": "string",
          "description": "File ID or path"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA256 checksum of transcript"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "line_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "approval": {
      "type": "object",
      "description": "Approval status tracking",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending_review", "approved", "needs_revision"],
          "default": "pending_review"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "approved_blocks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of approved block names"
        }
      }
    }
  }
}
