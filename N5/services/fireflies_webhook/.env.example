# Fireflies API Configuration
FIREFLIES_API_KEY=your-api-key-here

# Webhook Security (optional but recommended)
FIREFLIES_WEBHOOK_SECRET=

# Service Configuration
HOST=0.0.0.0
PORT=8765

# Database
