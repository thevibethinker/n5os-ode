{
  "version": "2.0.0",
  "last_updated": "2026-01-15",
  "description": "V's 3-slot emoji system for thread titles: State | Type | Content",
  "format": {
    "pattern": "MMM DD | {state} {type} {content} Title",
    "example": "Jan 14 | ✅ 👷🏽‍♂️ 🏗️ N5 Import Path Fixes",
    "slots": 3,
    "notes": "All 3 slots required. Use 📌 for normal threads."
  },
  "slots": {
    "1_state": {
      "description": "Thread completion/progress state",
      "required": true,
      "emojis": {
        "✅": {"name": "complete", "meaning": "Thread completed successfully"},
        "⏸️": {"name": "paused", "meaning": "Action pending, thread paused"},
        "‼️": {"name": "critical", "meaning": "Critical action pending"},
        "🚧": {"name": "in_progress", "meaning": "Work in progress, to be resumed"},
        "❌": {"name": "failed", "meaning": "Thread ended with unresolved errors"}
      }
    },
    "2_type": {
      "description": "Thread structural type",
      "required": true,
      "emojis": {
        "📌": {"name": "normal", "meaning": "Normal standalone thread (default)"},
        "🐙": {"name": "orchestrator", "meaning": "Orchestrator thread coordinating workers"},
        "👷🏽‍♂️": {"name": "worker", "meaning": "Worker thread spawned by orchestrator"},
        "🔗": {"name": "linked", "meaning": "Part of a series (use with #N)"}
      }
    },
    "3_content": {
      "description": "Primary content/work type",
      "required": true,
      "emojis": {
        "🏗️": {"name": "build", "meaning": "Building functionality, features, systems"},
        "🔎": {"name": "research", "meaning": "Search, query, research, investigation"},
        "🛠️": {"name": "repair", "meaning": "Repair, debug, fix, troubleshoot"},
        "🕸️": {"name": "site", "meaning": "Site/web app related work"},
        "🪵": {"name": "log", "meaning": "Log entries, lists, tracking"},
        "✍️": {"name": "content", "meaning": "Content creation, writing, drafting"},
        "🪞": {"name": "reflection", "meaning": "Reflection, Socratic discourse, strategizing"},
        "🤳": {"name": "social", "meaning": "Social media related work"},
        "📊": {"name": "data", "meaning": "Data work, analytics, datasets"},
        "💬": {"name": "comms", "meaning": "Communications, email, outreach"},
        "🗂️": {"name": "organize", "meaning": "Organization, cleanup, filing"},
        "📝": {"name": "planning", "meaning": "Planning, roadmapping, design"}
      }
    }
  },
  "detection_hints": {
    "state": {
      "complete": ["status=closed", "all tasks done", "objectives met"],
      "paused": ["waiting on", "pending", "to be resumed", "blocked"],
      "critical": ["urgent", "critical", "ASAP", "blocking"],
      "in_progress": ["WIP", "continuing", "mid-work"],
      "failed": ["error", "failed", "crashed", "unresolved"]
    },
    "type": {
      "normal": ["default", "standalone", "single thread"],
      "orchestrator": ["orchestrator", "spawns workers", "coordinates", "parent thread"],
      "worker": ["worker", "spawned by", "W1-", "W2-", "WORKER_ASSIGNMENT"],
      "linked": ["#2", "#3", "part of series", "continuation"]
    },
    "content": {
      "build": ["build", "implement", "create", "feature", "capability"],
      "research": ["research", "search", "find", "query", "investigate"],
      "repair": ["fix", "debug", "repair", "troubleshoot", "bug"],
      "site": ["site", "website", "web app", "deploy site"],
      "log": ["log", "list", "track", "entries"],
      "content": ["write", "draft", "content", "article", "post"],
      "reflection": ["reflect", "strategy", "think through", "Socratic"],
      "social": ["social", "twitter", "linkedin", "X post"],
      "data": ["data", "dataset", "analytics", "metrics"],
      "comms": ["email", "message", "outreach", "follow-up"],
      "organize": ["cleanup", "organize", "file", "reconcile"],
      "planning": ["plan", "roadmap", "design", "architecture"]
    }
  }
}


