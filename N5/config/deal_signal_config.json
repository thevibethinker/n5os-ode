{
  "version": "1.0",
  "created": "2026-01-18",
  
  "matching": {
    "min_confidence_threshold": 70,
    "high_confidence_threshold": 90,
    "max_deals_to_include": 100,
    "max_contacts_to_include": 50
  },
  
  "signals": {
    "stage_progression": [
      "identified",
      "researched",
      "outreach",
      "engaged",
      "qualified",
      "negotiating",
      "closed_won"
    ],
    "terminal_stages": ["closed_won", "closed_lost"],
    "auto_advance_signals": {
      "outreach": ["sent email", "sent message", "reached out", "made contact"],
      "engaged": ["responded", "replied", "got back", "heard back"],
      "qualified": ["interested", "want to move forward", "ready to proceed", "confirmed interest"],
      "negotiating": ["discussing terms", "talking pricing", "working on structure", "negotiating"],
      "closed_won": ["closed", "signed", "deal done", "completed"],
      "closed_lost": ["passed", "declined", "not interested", "dead", "no longer pursuing"]
    }
  },
  
  "sources": {
    "sms": {
      "prefix": "n5 deal",
      "enabled": true
    },
    "email": {
      "scan_enabled": true,
      "lookback_days": 7
    },
    "meeting": {
      "enabled": true,
      "block_types": ["B01", "B08", "B13", "B25", "B37"]
    },
    "kondo": {
      "enabled": true,
      "webhook_source": "linkedin"
    }
  },
  
  "llm": {
    "model": "claude-3-5-sonnet-20241022",
    "fallback_model": "claude-3-haiku-20240307",
    "temperature": 0.1,
    "max_retries": 2,
    "timeout_seconds": 30
  },
  
  "sync": {
    "notion_enabled": true,
    "append_intel_on_update": true,
    "local_first": true
  },
  
  "proactive": {
    "new_deal_detection": true,
    "require_sms_approval": true,
    "approval_timeout_hours": 24
  }
}
