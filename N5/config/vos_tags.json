  "auto_inheritance": {
    "description": "Automatic tag inheritance rules when primary tags are applied",
    "rules": {
      "[LD-INV]": {
        "inherits": ["[!!]"],
        "n5_inherits": ["#priority:critical"],
        "reason": "All investors are business-critical"
      },
      "#stakeholder:customer": {
        "inherits_n5": ["#priority:critical"],
        "reason": "Paying customers are critical to business"
      },
      "#stakeholder:advisor": {
        "inherits_n5": ["#priority:critical"],
        "reason": "Strategic advisors provide high-value guidance"
      }
    }
  },

  "disambiguation": {
    "description": "Rules for resolving ambiguous tag contexts",
    "[LD-NET]": {
      "default": "#stakeholder:partner:collaboration",
      "channel_keywords": ["distribution", "resale", "reseller", "referral partner", "affiliate", "channel partner", "distributor"],
      "collaboration_keywords": ["integration", "API", "co-marketing", "joint", "embedded", "partnership", "co-develop"],
      "fallback": "Default to collaboration, flag for manual review if ambiguous"
    }
  }
