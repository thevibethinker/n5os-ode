{
  "version": "1.0.0",
  "description": "Bidirectional mapping between N5 hashtags and Howie V-OS brackets",
  "hashtag_to_bracket": {
    "#stakeholder:investor": "[LD-INV]",
    "#stakeholder:job_seeker": "[LD-HIR]",
    "#stakeholder:community": "[LD-COM]",
    "#stakeholder:partner:collaboration": "[LD-NET]",
    "#stakeholder:partner:channel": "[LD-NET]",
    "#stakeholder:partner": "[LD-NET]",
    "#stakeholder:prospect": "[LD-GEN]",
    "#priority:critical": "!!",
    "#priority:high": "[A-0]",
    "#priority:normal": "[A-1]",
    "#priority:low": "[A-2]",
    "#schedule:within_5d": "[D5]",
    "#schedule:5d_plus": "[D5+]",
    "#schedule:10d_plus": "[D10]",
    "#status:postponed": "[OFF]",
    "#status:awaiting": "[AWA]",
    "#status:inactive": "[TERM]",
    "#align:logan": "[LOG]",
    "#align:ilse": "[ILS]",
    "#align:founders": "[GPT-F]",
    "#accommodation:minimal": "[A-0]",
    "#accommodation:baseline": "[A-1]",
    "#accommodation:full": "[A-2]",
    "#availability:weekend_ok": "[WEX]",
    "#availability:weekend_preferred": "[WEP]",
    "#type:discovery": "",
    "#type:partnership": "",
    "#type:followup": "",
    "#type:recurring": ""
  },
  "bracket_to_hashtag": {
    "[LD-INV]": "#stakeholder:investor",
    "[LD-HIR]": "#stakeholder:job_seeker",
    "[LD-COM]": "#stakeholder:community",
    "[LD-NET]": "#stakeholder:partner:collaboration",
    "[LD-GEN]": "#stakeholder:prospect",
    "!!": "#priority:critical",
    "[A-0]": "#priority:high",
    "[A-1]": "#priority:normal",
    "[A-2]": "#priority:low",
    "[D5]": "#schedule:within_5d",
    "[D5+]": "#schedule:5d_plus",
    "[D10]": "#schedule:10d_plus",
    "[OFF]": "#status:postponed",
    "[AWA]": "#status:awaiting",
    "[TERM]": "#status:inactive",
    "[LOG]": "#align:logan",
    "[ILS]": "#align:ilse",
    "[GPT-F]": "#align:founders",
    "[GPT-I]": "#priority:internal",
    "[GPT-E]": "#priority:external",
    "[WEX]": "#availability:weekend_ok",
    "[WEP]": "#availability:weekend_preferred"
  },
  "regex_patterns": {
    "[F-(\\d+)]": "#followup:external_$1",
    "[FL-(\\d+)]": "#followup:logan_$1",
    "[FM-(\\d+)]": "#followup:vrijen_$1"
  },
  "n5_only_tags": [
    "#relationship:*",
    "#engagement:*",
    "#context:*",
    "#stakeholder:customer",
    "#stakeholder:vendor",
    "#stakeholder:advisor"
  ],
  "auto_inheritance_rules": {
    "#stakeholder:investor": ["#priority:critical", "#type:discovery"],
    "#stakeholder:job_seeker": ["#type:discovery"],
    "#stakeholder:community": ["#type:partnership"],
    "#stakeholder:partner:collaboration": ["#type:discovery"],
    "#stakeholder:partner:channel": ["#type:partnership"],
    "#stakeholder:prospect": ["#type:discovery"]
  }
}
