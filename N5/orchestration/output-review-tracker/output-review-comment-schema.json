{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n5.local/schemas/output-review-comment.schema.json",
  "title": "N5 Output Review Comment",
  "type": "object",
  "required": ["id", "output_review_id", "created_at", "author", "comment"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^cmt_[0-9]{8}_[a-z0-9]+$",
      "description": "Unique identifier: cmt_YYYYMMDD_randomhex"
    },
    "output_review_id": {
      "type": "string",
      "pattern": "^or_[0-9]{8}_[a-z0-9]+$",
      "description": "ID of the output review this comment belongs to"
    },
    "parent_comment_id": {
      "type": ["string", "null"],
      "pattern": "^cmt_[0-9]{8}_[a-z0-9]+$",
      "description": "For threaded replies - ID of parent comment"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "type": "string",
      "description": "Who wrote this comment (V, Zo, etc.)"
    },
    "comment": {
      "type": "string",
      "description": "The comment text"
    },
    "context": {
      "type": ["object", "null"],
      "properties": {
        "line_numbers": {
          "type": "string",
          "description": "Line range this comment refers to (e.g., '45-52' or '23')"
        },
        "excerpt": {
          "type": "string",
          "description": "Brief excerpt of the content being commented on"
        }
      },
      "description": "Optional context for where in the output this comment applies"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "Tags for categorizing comments (tone, structure, etc.)"
    }
  }
}
