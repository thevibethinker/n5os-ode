#!/usr/bin/env python3
"""
N5 Thread Export - After-Action Report (AAR) Generator
Generate comprehensive AAR for conversation threads (AAR v2.0 protocol)

Usage:
    python3 n5_thread_export.py [thread_id] [--title "Title"] [--dry-run]
    python3 n5_thread_export.py --auto  # Auto-detect current thread
"""

import os
import sys
import json
import shutil
import argparse
from pathlib import Path
from datetime import datetime, timezone
from typing import Dict, List, Optional, Tuple

try:
    from jsonschema import Draft202012Validator
except ImportError:
    print("ERROR: jsonschema not installed. Run: pip install jsonschema", file=sys.stderr)
    sys.exit(1)

# Paths
ROOT = Path(__file__).resolve().parents[1]
SCHEMAS = ROOT / "schemas"
LOGS_DIR = ROOT / "logs" / "threads"
CONVERSATION_WS_ROOT = Path("/home/.z/workspaces")
AAR_SCHEMA_PATH = SCHEMAS / "aar.schema.json"

# Constants
AAR_VERSION = "2.0"


class ThreadExporter:
    """Handles AAR generation and thread export"""
    
    def __init__(self, thread_id: str, title: Optional[str] = None, dry_run: bool = False):
        self.thread_id = thread_id
        self.title = title
        self.dry_run = dry_run
        self.auto_confirm = False  # For automated execution
        self.is_checkpoint = False  # For progressive documentation
        self.conversation_ws = CONVERSATION_WS_ROOT / thread_id
        self.aar_data = {}
        self.artifacts = []
        
        # Archive directory (descriptive name)
        if title:
            safe_title = self._sanitize_title(title)
            self.archive_dir = LOGS_DIR / f"{thread_id}-{safe_title}"
        else:
            self.archive_dir = LOGS_DIR / thread_id
        
        self.aar_json_path = self.archive_dir / f"aar-{datetime.now().strftime('%Y-%m-%d')}.json"
        self.aar_md_path = self.archive_dir / f"aar-{datetime.now().strftime('%Y-%m-%d')}.md"
        self.artifacts_dir = self.archive_dir / "artifacts"
        self.checkpoint_path = self.archive_dir / f"checkpoint-{datetime.now().strftime('%Y-%m-%d-%H%M%S')}.json"
    
    def _sanitize_title(self, title: str) -> str:
        """Convert title to filesystem-safe string"""
        # Replace spaces with hyphens, remove special chars
        safe = title.lower()
        safe = safe.replace(' ', '-')
        safe = ''.join(c for c in safe if c.isalnum() or c == '-')
        safe = '-'.join(filter(None, safe.split('-')))  # Remove consecutive hyphens
        return safe[:60]  # Limit length
    
    def detect_thread_id(self) -> Optional[str]:
        """Auto-detect current conversation thread ID"""
        if not CONVERSATION_WS_ROOT.exists():
            return None
        
        # Find most recently modified con_* directory
        con_dirs = sorted(
            [d for d in CONVERSATION_WS_ROOT.iterdir() 
             if d.is_dir() and d.name.startswith("con_")],
            key=lambda d: d.stat().st_mtime,
            reverse=True
        )
        
        if con_dirs:
            return con_dirs[0].name
        return None
    
    def validate_thread(self) -> bool:
        """Check if thread workspace exists"""
        if not self.conversation_ws.exists():
            print(f"❌ Thread workspace not found: {self.conversation_ws}")
            return False
        return True
    
    def inventory_artifacts(self) -> List[Dict]:
        """Scan conversation workspace for artifacts"""
        artifacts = []
        
        if not self.conversation_ws.exists():
            return artifacts
        
        for filepath in self.conversation_ws.rglob("*"):
            if filepath.is_file():
                stat = filepath.stat()
                artifacts.append({
                    "filename": filepath.name,
                    "path": filepath,
                    "relative_path": filepath.relative_to(self.conversation_ws),
                    "size_bytes": stat.st_size,
                    "created_at": datetime.fromtimestamp(stat.st_ctime, tz=timezone.utc).isoformat(),
                    "modified_at": datetime.fromtimestamp(stat.st_mtime, tz=timezone.utc).isoformat(),
                    "type": self._classify_file(filepath)
                })
        
        return artifacts
    
    def _classify_file(self, filepath: Path) -> str:
        """Classify file by extension"""
        ext = filepath.suffix.lower()
        
        if ext in ['.py', '.sh', '.js', '.ts']:
            return "script"
        elif ext in ['.md', '.txt', '.pdf', '.docx']:
            return "document"
        elif ext in ['.json', '.jsonl', '.csv', '.yaml', '.yml']:
            return "data"
        elif ext in ['.png', '.jpg', '.jpeg', '.gif', '.svg']:
            return "image"
        elif ext in ['.toml', '.ini', '.conf', '.cfg']:
            return "config"
        else:
            return "other"
    
    def ask_interactive_questions(self) -> Dict:
        """Ask user 5 key questions for AAR"""
        print("\n" + "="*70)
        print("AFTER-ACTION REPORT (AAR) - Interactive Questions")
        print("="*70)
        print("\nPlease answer the following questions to generate the AAR:")
        print("(This helps capture the narrative context we can't access programmatically)\n")
        
        responses = {}
        
        # Question 1: Objective
        print("1. What was the PRIMARY OBJECTIVE of this conversation?")
        print("   (What were you trying to accomplish?)")
        responses['objective'] = input("   → ").strip()
        
        # Question 2: Key Decisions
        print("\n2. What were 2-3 KEY DECISIONS made during this conversation?")
        print("   (Important choices, directions taken)")
        print("   Enter decisions one per line. Press Enter twice when done.")
        decisions = []
        while True:
            decision = input("   → ").strip()
            if not decision:
                break
            decisions.append(decision)
        responses['decisions'] = decisions
        
        # Question 3: Outcomes
        print("\n3. What were the MAIN OUTCOMES/DELIVERABLES?")
        print("   (What was created, accomplished, or learned?)")
        responses['outcomes'] = input("   → ").strip()
        
        # Question 4: Next Steps
        print("\n4. What should happen NEXT?")
        print("   (Primary continuation objective)")
        responses['next_objective'] = input("   → ").strip()
        
        # Question 5: Challenges/Pivots
        print("\n5. Were there any significant CHALLENGES or PIVOTS?")
        print("   (Optional - press Enter to skip)")
        responses['challenges'] = input("   → ").strip()
        
        return responses
    
    def generate_aar_data(self, interactive_responses: Dict) -> Dict:
        """Generate AAR JSON structure"""
        now = datetime.now(timezone.utc)
        
        # Build key events from decisions
        key_events = []
        for idx, decision in enumerate(interactive_responses.get('decisions', []), 1):
            key_events.append({
                "description": decision,
                "rationale": "Key decision made during conversation",
                "type": "decision"
            })
        
        # Add challenges as events if provided
        if interactive_responses.get('challenges'):
            key_events.append({
                "description": interactive_responses['challenges'],
                "rationale": "Challenge or pivot encountered",
                "type": "challenge"
            })
        
        # Build artifacts list
        artifacts_data = []
        for artifact in self.artifacts:
            artifacts_data.append({
                "filename": str(artifact['relative_path']),
                "description": f"{artifact['type'].capitalize()} file created during conversation",
                "type": artifact['type'],
                "size_bytes": artifact['size_bytes'],
                "created_at": artifact['created_at'],
                "modified_at": artifact['modified_at']
            })
        
        # Generate next steps from objective
        next_steps = []
        if interactive_responses.get('next_objective'):
            next_steps.append({
                "action": interactive_responses['next_objective'],
                "details": "Primary continuation objective from AAR",
                "priority": "H"
            })
        
        # Build AAR structure
        aar = {
            "thread_id": self.thread_id,
            "archived_date": now.strftime("%Y-%m-%d"),
            "title": self.title or f"Conversation {self.thread_id}",
            "executive_summary": {
                "purpose": interactive_responses.get('objective', 'No objective specified'),
                "outcome": interactive_responses.get('outcomes', 'No outcomes specified')
            },
            "key_events": key_events if key_events else [{
                "description": "No key events captured",
                "rationale": "Interactive responses not provided",
                "type": "milestone"
            }],
            "final_state": {
                "summary": f"Created {len(artifacts_data)} artifacts during conversation",
                "artifacts": artifacts_data
            },
            "primary_objective": interactive_responses.get('next_objective', 'No next objective specified'),
            "next_steps": next_steps if next_steps else [{
                "action": "Review AAR and determine next steps",
                "details": "No specific next steps defined"
            }],
            "aar_version": AAR_VERSION,
            "telemetry": {
                "artifacts_created": len(artifacts_data),
                "total_size_bytes": sum(a['size_bytes'] for a in self.artifacts),
                "aar_generated_by": "Vrijen The Vibe Thinker (Zo)",
                "aar_generation_method": "interactive"
            },
            "metadata": {
                "ended_at": now.isoformat()
            }
        }
        
        return aar
    
    def generate_modular_exports(self, aar_data: Dict) -> Dict[str, str]:
        """Generate modular markdown exports (6 files) for better context loading
        
        Returns dict mapping filename -> markdown content:
        - INDEX.md: Navigation and structure
        - RESUME.md: Entry point for quick resume
        - DECISIONS.md: Design rationale and lessons
        - TECHNICAL.md: How-to and current state
        - TROUBLESHOOTING.md: Diagnostic guide
        - LINEAGE.md: History and relationships
        """
        exports = {}
        
        # Extract common data
        thread_id = self.thread_id
        export_date = datetime.now(timezone.utc).strftime('%Y-%m-%d')
        topic = aar_data.get('executive_summary', {}).get('purpose', 'Thread work')
        status = aar_data.get('status', 'Complete')
        artifacts = self.artifacts
        telemetry = aar_data.get('telemetry', {})
        
        # ===== INDEX.md =====
        idx = []
        idx.append("# Thread Export Index")
        idx.append("")
        idx.append(f"**Thread ID:** {thread_id}  ")
        idx.append(f"**Export Date:** {export_date}  ")
        idx.append(f"**Topic:** {topic}")
        idx.append("")
        idx.append("---")
        idx.append("")
        idx.append("## How to Use These Files")
        idx.append("")
        idx.append("This thread export has been split into 5 focused files for efficient context loading:")
        idx.append("")
        idx.append("| File | Purpose | When to Load |")
        idx.append("|------|---------|--------------|")
        idx.append("| `RESUME.md` | Quick resume entry point | **Always load first** |")
        idx.append("| `DECISIONS.md` | Design rationale & lessons | When understanding why things are the way they are |")
        idx.append("| `TECHNICAL.md` | How-to & current state | During active work execution |")
        idx.append("| `TROUBLESHOOTING.md` | Diagnostic guide | When stuck or encountering issues |")
        idx.append("| `LINEAGE.md` | History & relationships | For planning or understanding broader context |")
        idx.append("")
        idx.append("### Quick Start Workflow")
        idx.append("")
        idx.append("1. **Load `RESUME.md`** - Get oriented (what happened, what's next)")
        idx.append("2. **Scan summary** - Decide which other files you need")
        idx.append("3. **Load selectively:**")
        idx.append("   - Making changes? → Load `DECISIONS.md` to understand rationale")
        idx.append("   - Executing tasks? → Load `TECHNICAL.md` for reference")
        idx.append("   - Hit a wall? → Load `TROUBLESHOOTING.md`")
        idx.append("   - Planning next phase? → Load `LINEAGE.md`")
        idx.append("")
        idx.append("### File Statistics")
        idx.append("")
        artifact_count = len(artifacts)
        total_bytes = sum(a.get('size_bytes', 0) for a in artifacts)
        idx.append(f"- **Artifacts:** {artifact_count} files ({total_bytes / 1024:.1f} KB)")
        idx.append(f"- **AAR Version:** {AAR_VERSION}")
        idx.append(f"- **Export Format:** Modular (v2.1)")
        idx.append("")
        idx.append("---")
        idx.append("")
        idx.append("**Also available:** `aar.json` (machine-readable source of truth)")
        idx.append("")
        exports['INDEX.md'] = '\n'.join(idx)
        
        # ===== RESUME.md =====
        resume = []
        resume.append("# Thread Export: Resume")
        resume.append("")
        resume.append(f"**Thread ID:** {thread_id}  ")
        resume.append(f"**Export Date:** {export_date}  ")
        resume.append(f"**Topic:** {topic}  ")
        resume.append(f"**Status:** {status}")
        resume.append("")
        resume.append("---")
        resume.append("")
        resume.append("## Summary")
        resume.append("")
        purpose = aar_data.get('executive_summary', {}).get('purpose', 'No objective specified')
        outcome = aar_data.get('executive_summary', {}).get('outcome', 'No outcomes specified')
        next_obj = aar_data.get('primary_objective', 'Review and determine next steps')
        resume.append(f"{purpose} {outcome} Next: {next_obj}")
        resume.append("")
        resume.append("---")
        resume.append("")
        resume.append("## Quick Start")
        resume.append("")
        resume.append("**First 10 minutes:**")
        resume.append("")
        resume.append("1. **Verify state** (2 min)")
        resume.append("   ```bash")
        resume.append("   # Check key files/resources exist")
        if artifacts:
            for f in [a['filename'] for a in artifacts[:3]]:
                resume.append(f"   ls -la {f}")
        else:
            resume.append("   # No artifacts to verify")
        resume.append("   ```")
        resume.append("   Expected: Files should exist with appropriate sizes")
        resume.append("")
        resume.append("2. **Understand context** (3 min)")
        resume.append("   - Read \"Critical Constraints\" below")
        resume.append("   - Skim \"What Was Completed\"")
        resume.append("   - Note \"Known Issues\"")
        resume.append("")
        resume.append("3. **Start work** (5 min)")
        if next_steps:
            resume.append(f"   - {next_steps[0].get('action', 'Review AAR and plan next actions')}")
            resume.append("   - Expected: Progress on primary objective")
        else:
            resume.append("   - Review AAR and plan next actions")
        resume.append("")
        resume.append("---")
        resume.append("")
        exports['RESUME.md'] = '\n'.join(resume)
        
        # ===== DECISIONS.md =====
        decisions_md = []
        decisions_md.append("# Thread Export: Key Decisions")
        decisions_md.append("")
        decisions_md.append(f"**Thread ID:** {thread_id}  ")
        decisions_md.append(f"**Export Date:** {export_date}  ")
        decisions_md.append(f"**Topic:** {topic}  ")
        decisions_md.append(f"**Status:** {status}")
        decisions_md.append("")
        decisions_md.append("---")
        decisions_md.append("")
        decisions_md.append("## Critical Constraints")
        decisions_md.append("")
        constraints = aar_data.get('executive_summary', {}).get('constraints', [])
        decisions = aar_data.get('key_decisions', [])
        if constraints or decisions:
            decisions_md.append("**DO NOT CHANGE:**")
            if constraints:
                for constraint in constraints:
                    decisions_md.append(f"- ❌ {constraint}")
            else:
                decisions_md.append("- ❌ (To be documented)")
            decisions_md.append("")
            decisions_md.append("**MUST PRESERVE:**")
            decisions_md.append("- ✅ Existing functionality and interfaces")
            decisions_md.append("- ✅ Data formats and schemas")
            decisions_md.append("- ✅ Integration points with other systems")
            decisions_md.append("")
        else:
            decisions_md.append("No specific constraints documented. Exercise caution when making changes.")
            decisions_md.append("")
        decisions_md.append("---")
        decisions_md.append("")
        decisions_md.append("## Key Technical Decisions")
        decisions_md.append("")
        key_decisions = aar_data.get('key_decisions', [])
        if key_decisions:
            for i, decision in enumerate(key_decisions, 1):
                if isinstance(decision, dict):
                    decisions_md.append(f"### Decision {i}: {decision.get('topic', 'Technical Choice')}")
                    decisions_md.append(f"- **Choice made:** {decision.get('decision', 'See details')}")
                    decisions_md.append(f"- **Rationale:** {decision.get('rationale', 'Not documented')}")
                    if decision.get('alternatives'):
                        decisions_md.append("- **Alternatives considered:**")
                        for alt in decision['alternatives']:
                            decisions_md.append(f"  - {alt}")
                    decisions_md.append("")
                else:
                    decisions_md.append(f"### Decision {i}")
                    decisions_md.append(f"- {decision}")
                    decisions_md.append("")
        else:
            decisions_md.append("No technical decisions explicitly documented in this thread.")
            decisions_md.append("")
        decisions_md.append("---")
        decisions_md.append("")
        exports['DECISIONS.md'] = '\n'.join(decisions_md)
        
        # ===== TECHNICAL.md =====
        technical = []
        technical.append("# Thread Export: Technical Details")
        technical.append("")
        technical.append(f"**Thread ID:** {thread_id}  ")
        technical.append(f"**Export Date:** {export_date}  ")
        technical.append(f"**Topic:** {topic}  ")
        technical.append(f"**Status:** {status}")
        technical.append("")
        technical.append("---")
        technical.append("")
        technical.append("## What Was Completed")
        technical.append("")
        if artifacts:
            by_type = {}
            for artifact in artifacts:
                atype = artifact.get('type', 'other')
                by_type.setdefault(atype, []).append(artifact)
            
            idx = 1
            for atype, items in by_type.items():
                technical.append(f"### {idx}. {atype.capitalize()} Artifacts")
                if len(items) == 1:
                    a = items[0]
                    technical.append(f"- **File(s):** `file '{a['filename']}'`")
                    technical.append(f"- **Purpose:** {a.get('description', 'Artifact created during conversation')}")
                    technical.append("- **Status:** ✅ Complete")
                else:
                    technical.append(f"- **File(s):** {len(items)} {atype} files")
                    technical.append(f"- **Purpose:** {atype.capitalize()} artifacts created during conversation")
                    technical.append("- **Files:**")
                    for a in items:
                        size_kb = a.get('size_bytes', 0) / 1024
                        technical.append(f"  - `{a['filename']}` ({size_kb:.1f} KB)")
                    technical.append("- **Status:** ✅ Complete")
                technical.append("")
                idx += 1
        else:
            technical.append("No artifacts were created during this conversation.")
            technical.append("")
        technical.append("---")
        technical.append("")
        technical.append("## Code Patterns / Quick Reference")
        technical.append("")
        code_examples = aar_data.get('code_patterns', [])
        if code_examples:
            for pattern in code_examples:
                if isinstance(pattern, dict):
                    technical.append(f"### {pattern.get('category', 'Pattern')}")
                    technical.append("")
                    technical.append("```" + pattern.get('language', 'python'))
                    technical.append(pattern.get('code', '# Example code'))
                    technical.append("```")
                    if pattern.get('description'):
                        technical.append(f"_{pattern['description']}_")
                    technical.append("")
        else:
            # Infer patterns from artifacts
            scripts = [a for a in artifacts if a.get('type') == 'script']
            if scripts:
                technical.append("### Common Operations")
                technical.append("")
                technical.append("| Task | Command | Notes |")
                technical.append("|------|---------|-------|")
                for script in scripts[:5]:
                    script_name = Path(script['filename']).name
                    ext = Path(script['filename']).suffix
                    if ext == '.py':
                        technical.append(f"| Run {script_name} | `python3 {script['filename']}` | Execute script |")
                    elif ext == '.sh':
                        technical.append(f"| Run {script_name} | `bash {script['filename']}` | Execute script |")
                technical.append("")
            else:
                technical.append("No code patterns documented in this thread.")
                technical.append("")
        technical.append("---")
        technical.append("")
        technical.append("## State Snapshot")
        technical.append("")
        technical.append(f"**As of export ({export_date}):**")
        technical.append("")
        
        technical.append("### File System")
        if artifacts:
            technical.append("```")
            by_type = {}
            for a in artifacts:
                atype = a.get('type', 'other')
                by_type.setdefault(atype, []).append(a)
            
            for atype, files in sorted(by_type.items()):
                if len(files) == 1:
                    size_kb = files[0].get('size_bytes', 0) / 1024
                    technical.append(f"{files[0]['filename']} ({size_kb:.1f} KB)")
                else:
                    technical.append(f"{atype}/")
                    for f in files[:10]:
                        size_kb = f.get('size_bytes', 0) / 1024
                        fname = Path(f['filename']).name
                        technical.append(f"├── {fname} ({size_kb:.1f} KB)")
                    if len(files) > 10:
                        technical.append(f"└── ... and {len(files) - 10} more")
            technical.append("```")
            technical.append("")
        else:
            technical.append("No file system artifacts.")
            technical.append("")
        
        technical.append("### Key Metrics")
        artifact_count = telemetry.get('artifacts_created', len(artifacts))
        total_bytes = telemetry.get('total_size_bytes', sum(a.get('size_bytes', 0) for a in artifacts))
        total_mb = total_bytes / (1024 * 1024)
        technical.append(f"- **Artifacts created:** {artifact_count}")
        technical.append(f"- **Total size:** {total_mb:.2f} MB")
        technical.append(f"- **Generation method:** {telemetry.get('aar_generation_method', 'unknown')}")
        technical.append("")
        technical.append("---")
        technical.append("")
        exports['TECHNICAL.md'] = '\n'.join(technical)
        
        # ===== TROUBLESHOOTING.md =====
        troubleshooting_md = []
        troubleshooting_md.append("# Thread Export: Troubleshooting Guide")
        troubleshooting_md.append("")
        troubleshooting_md.append(f"**Thread ID:** {thread_id}  ")
        troubleshooting_md.append(f"**Export Date:** {export_date}  ")
        troubleshooting_md.append(f"**Topic:** {topic}  ")
        troubleshooting_md.append(f"**Status:** {status}")
        troubleshooting_md.append("")
        troubleshooting_md.append("---")
        troubleshooting_md.append("")
        troubleshooting_md.append("## Known Issues / Gotchas")
        troubleshooting_md.append("")
        challenges = aar_data.get('challenges', [])
        if challenges:
            for challenge in challenges:
                if isinstance(challenge, dict):
                    issue_type = challenge.get('severity', 'Info')
                    icon = "🐛" if "bug" in issue_type.lower() else "⚠️"
                    troubleshooting_md.append(f"### {icon} Issue: {challenge.get('title', 'Unknown')}")
                    troubleshooting_md.append(f"- **Problem:** {challenge.get('problem', 'Not specified')}")
                    if challenge.get('workaround'):
                        troubleshooting_md.append(f"- **Workaround:** {challenge['workaround']}")
                    if challenge.get('solution'):
                        troubleshooting_md.append(f"- **Solution:** {challenge['solution']}")
                    troubleshooting_md.append("")
                else:
                    troubleshooting_md.append(f"### ⚠️ Note")
                    troubleshooting_md.append(f"- {challenge}")
                    troubleshooting_md.append("")
        else:
            troubleshooting_md.append("No known issues or gotchas documented.")
            troubleshooting_md.append("")
        troubleshooting_md.append("---")
        troubleshooting_md.append("")
        troubleshooting_md.append("## Anti-Patterns / Rejected Approaches")
        troubleshooting_md.append("")
        rejected = aar_data.get('rejected_approaches', [])
        if rejected:
            for approach in rejected:
                if isinstance(approach, dict):
                    troubleshooting_md.append(f"### ❌ Approach: {approach.get('name', 'Unnamed')}")
                    troubleshooting_md.append(f"- **Why rejected:** {approach.get('reason', 'Not specified')}")
                    if approach.get('lesson'):
                        troubleshooting_md.append(f"- **Lesson learned:** {approach['lesson']}")
                    troubleshooting_md.append("")
                else:
                    troubleshooting_md.append(f"### ❌ {approach}")
                    troubleshooting_md.append("")
        else:
            troubleshooting_md.append("No rejected approaches documented. All attempted approaches were successful or iteration is ongoing.")
            troubleshooting_md.append("")
        troubleshooting_md.append("---")
        troubleshooting_md.append("")
        exports['TROUBLESHOOTING.md'] = '\n'.join(troubleshooting_md)
        
        # ===== LINEAGE.md =====
        lineage_md = []
        lineage_md.append("# Thread Export: Thread Lineage & Related Work")
        lineage_md.append("")
        lineage_md.append(f"**Thread ID:** {thread_id}  ")
        lineage_md.append(f"**Export Date:** {export_date}  ")
        lineage_md.append(f"**Topic:** {topic}  ")
        lineage_md.append(f"**Status:** {status}")
        lineage_md.append("")
        lineage_md.append("---")
        lineage_md.append("")
        lineage_md.append("## Thread Lineage & Related Work")
        lineage_md.append("")
        lineage = aar_data.get('lineage', {})
        if lineage:
            if lineage.get('previous_threads'):
                lineage_md.append("### Previous Related Threads")
                for thread in lineage['previous_threads']:
                    if isinstance(thread, dict):
                        lineage_md.append(f"- Thread {thread.get('id', 'unknown')}: {thread.get('topic', 'Related work')}")
                        if thread.get('relationship'):
                            lineage_md.append(f"  - Relationship: {thread['relationship']}")
                    else:
                        lineage_md.append(f"- {thread}")
                lineage_md.append("")
            
            if lineage.get('related_components'):
                lineage_md.append("### Related System Components")
                for component in lineage['related_components']:
                    lineage_md.append(f"- {component}")
                lineage_md.append("")
        else:
            lineage_md.append("No explicit thread lineage documented. This may be a standalone conversation.")
            lineage_md.append("")
            lineage_md.append("### To find related work:")
            lineage_md.append("```bash")
            lineage_md.append("# Search for related threads by topic")
            lineage_md.append("ls -lt N5/logs/threads/ | head -20")
            lineage_md.append("")
            lineage_md.append("# Search for similar content")
            lineage_md.append("grep -r 'relevant keyword' N5/logs/threads/")
            lineage_md.append("```")
            lineage_md.append("")
        lineage_md.append("---")
        lineage_md.append("")
        exports['LINEAGE.md'] = '\n'.join(lineage_md)
        
        return exports
    
    def validate_aar(self, aar_data: Dict) -> Tuple[bool, List[str]]:
        """Validate AAR against schema"""
        if not AAR_SCHEMA_PATH.exists():
            return False, [f"Schema not found: {AAR_SCHEMA_PATH}"]
        
        with open(AAR_SCHEMA_PATH) as f:
            schema = json.load(f)
        
        validator = Draft202012Validator(schema)
        errors = sorted(validator.iter_errors(aar_data), key=lambda e: e.path)
        
        if errors:
            error_messages = []
            for e in errors:
                path = '.'.join(map(str, e.path)) or '<root>'
                error_messages.append(f"  - {path}: {e.message}")
            return False, error_messages
        
        return True, []
    
    def generate_markdown(self, aar_data: Dict) -> str:
        """Generate markdown view from AAR JSON using v2.0 format specification"""
        md = []
        
        # Extract common data
        title = aar_data.get('title', 'Thread Export')
        thread_id = aar_data.get('thread_id', 'unknown')
        export_date = aar_data.get('archived_date', datetime.now().strftime("%Y-%m-%d"))
        topic = aar_data.get('executive_summary', {}).get('purpose', 'Thread export')
        if len(topic) > 100:
            topic = topic[:97] + "..."
        status = "Complete"
        artifacts = aar_data.get('final_state', {}).get('artifacts', [])
        key_events = aar_data.get('key_events', [])
        next_steps = aar_data.get('next_steps', [])
        telemetry = aar_data.get('telemetry', {})
        
        # HEADER
        md.append(f"# Thread Export: {title}")
        md.append("")
        md.append(f"**Thread ID:** {thread_id}  ")
        md.append(f"**Export Date:** {export_date}  ")
        md.append(f"**Topic:** {topic}  ")
        md.append(f"**Status:** {status}")
        md.append("")
        md.append("---")
        md.append("")
        
        # SUMMARY
        md.append("## Summary")
        md.append("")
        purpose = aar_data.get('executive_summary', {}).get('purpose', 'No objective specified')
        outcome = aar_data.get('executive_summary', {}).get('outcome', 'No outcomes specified')
        next_obj = aar_data.get('primary_objective', 'Review and determine next steps')
        md.append(f"{purpose} {outcome} Next: {next_obj}")
        md.append("")
        md.append("---")
        md.append("")
        
        # QUICK START
        md.append("## Quick Start")
        md.append("")
        md.append("**First 10 minutes:**")
        md.append("")
        md.append("1. **Verify state** (2 min)")
        md.append("   ```bash")
        md.append("   # Check key files/resources exist")
        if artifacts:
            for f in [a['filename'] for a in artifacts[:3]]:
                md.append(f"   ls -la {f}")
        else:
            md.append("   # No artifacts to verify")
        md.append("   ```")
        md.append("   Expected: Files should exist with appropriate sizes")
        md.append("")
        md.append("2. **Understand context** (3 min)")
        md.append("   - Read \"Critical Constraints\" below")
        md.append("   - Skim \"What Was Completed\"")
        md.append("   - Note \"Known Issues\"")
        md.append("")
        md.append("3. **Start work** (5 min)")
        if next_steps:
            md.append(f"   - {next_steps[0].get('action', 'Review AAR and plan next actions')}")
            md.append("   - Expected: Progress on primary objective")
        else:
            md.append("   - Review AAR and plan next actions")
        md.append("")
        md.append("---")
        md.append("")
        
        # WHAT WAS COMPLETED
        md.append("## What Was Completed")
        md.append("")
        if artifacts:
            by_type = {}
            for artifact in artifacts:
                atype = artifact.get('type', 'other')
                by_type.setdefault(atype, []).append(artifact)
            
            idx = 1
            for atype, items in by_type.items():
                md.append(f"### {idx}. {atype.capitalize()} Artifacts")
                if len(items) == 1:
                    a = items[0]
                    md.append(f"- **File(s):** `file '{a['filename']}'`")
                    md.append(f"- **Purpose:** {a.get('description', 'Artifact created during conversation')}")
                    md.append("- **Status:** ✅ Complete")
                else:
                    md.append(f"- **File(s):** {len(items)} {atype} files")
                    md.append(f"- **Purpose:** {atype.capitalize()} artifacts created during conversation")
                    md.append("- **Files:**")
                    for a in items:
                        size_kb = a.get('size_bytes', 0) / 1024
                        md.append(f"  - `{a['filename']}` ({size_kb:.1f} KB)")
                    md.append("- **Status:** ✅ Complete")
                md.append("")
                idx += 1
        else:
            md.append("No artifacts were created during this conversation.")
            md.append("")
        md.append("---")
        md.append("")
        
        # CRITICAL CONSTRAINTS
        md.append("## Critical Constraints")
        md.append("")
        constraints = aar_data.get('executive_summary', {}).get('constraints', [])
        decisions = aar_data.get('key_decisions', [])
        if constraints or decisions:
            md.append("**DO NOT CHANGE:**")
            if constraints:
                for constraint in constraints:
                    md.append(f"- ❌ {constraint}")
            else:
                md.append("- ❌ (To be documented)")
            md.append("")
            md.append("**MUST PRESERVE:**")
            md.append("- ✅ Existing functionality and interfaces")
            md.append("- ✅ Data formats and schemas")
            md.append("- ✅ Integration points with other systems")
            md.append("")
        else:
            md.append("No specific constraints documented. Exercise caution when making changes.")
            md.append("")
        md.append("---")
        md.append("")
        
        # KEY TECHNICAL DECISIONS
        md.append("## Key Technical Decisions")
        md.append("")
        key_decisions = aar_data.get('key_decisions', [])
        if key_decisions:
            for i, decision in enumerate(key_decisions, 1):
                if isinstance(decision, dict):
                    md.append(f"### Decision {i}: {decision.get('topic', 'Technical Choice')}")
                    md.append(f"- **Choice made:** {decision.get('decision', 'See details')}")
                    md.append(f"- **Rationale:** {decision.get('rationale', 'Not documented')}")
                    if decision.get('alternatives'):
                        md.append("- **Alternatives considered:**")
                        for alt in decision['alternatives']:
                            md.append(f"  - {alt}")
                    md.append("")
                else:
                    md.append(f"### Decision {i}")
                    md.append(f"- {decision}")
                    md.append("")
        else:
            md.append("No technical decisions explicitly documented in this thread.")
            md.append("")
        md.append("---")
        md.append("")
        
        # KNOWN ISSUES / GOTCHAS
        md.append("## Known Issues / Gotchas")
        md.append("")
        challenges = aar_data.get('challenges', [])
        if challenges:
            for challenge in challenges:
                if isinstance(challenge, dict):
                    issue_type = challenge.get('severity', 'Info')
                    icon = "🐛" if "bug" in issue_type.lower() else "⚠️"
                    md.append(f"### {icon} Issue: {challenge.get('title', 'Unknown')}")
                    md.append(f"- **Problem:** {challenge.get('problem', 'Not specified')}")
                    if challenge.get('workaround'):
                        md.append(f"- **Workaround:** {challenge['workaround']}")
                    if challenge.get('solution'):
                        md.append(f"- **Solution:** {challenge['solution']}")
                    md.append("")
                else:
                    md.append(f"### ⚠️ Note")
                    md.append(f"- {challenge}")
                    md.append("")
        else:
            md.append("No known issues or gotchas documented.")
            md.append("")
        md.append("---")
        md.append("")
        
        # ANTI-PATTERNS / REJECTED APPROACHES
        md.append("## Anti-Patterns / Rejected Approaches")
        md.append("")
        rejected = aar_data.get('rejected_approaches', [])
        if rejected:
            for approach in rejected:
                if isinstance(approach, dict):
                    md.append(f"### ❌ Approach: {approach.get('name', 'Unnamed')}")
                    md.append(f"- **Why rejected:** {approach.get('reason', 'Not specified')}")
                    if approach.get('lesson'):
                        md.append(f"- **Lesson learned:** {approach['lesson']}")
                    md.append("")
                else:
                    md.append(f"### ❌ {approach}")
                    md.append("")
        else:
            md.append("No rejected approaches documented. All attempted approaches were successful or iteration is ongoing.")
            md.append("")
        md.append("---")
        md.append("")
        
        # INTEGRATION POINTS & NEXT STEPS
        md.append("## Integration Points & Next Steps")
        md.append("")
        next_steps_data = aar_data.get('next_steps', [])
        if next_steps_data:
            md.append("### Pending Actions")
            md.append("")
            for i, step in enumerate(next_steps_data, 1):
                if isinstance(step, dict):
                    action = step.get('action', 'Action not specified')
                    priority = step.get('priority', 'M')
                    md.append(f"#### {i}. {action}")
                    if step.get('details'):
                        md.append(f"- **Details:** {step['details']}")
                    md.append(f"- **Priority:** {priority}")
                    md.append(f"- **Status:** {step.get('status', '⏳ Pending')}")
                    md.append("")
                else:
                    md.append(f"{i}. {step}")
                    md.append("")
        else:
            md.append("No specific next steps documented. Review thread and determine appropriate actions.")
            md.append("")
        
        md.append("### Integration Points")
        md.append("")
        dependencies = aar_data.get('dependencies', [])
        if dependencies:
            md.append("**Systems/Components:**")
            for dep in dependencies:
                if isinstance(dep, dict):
                    md.append(f"- **{dep.get('name', 'Unknown')}**: {dep.get('relationship', 'Related')}")
                else:
                    md.append(f"- {dep}")
            md.append("")
        else:
            md.append("No explicit integration points documented.")
            md.append("")
        md.append("---")
        md.append("")
        
        # CODE PATTERNS / QUICK REFERENCE
        md.append("## Code Patterns / Quick Reference")
        md.append("")
        code_examples = aar_data.get('code_patterns', [])
        if code_examples:
            for pattern in code_examples:
                if isinstance(pattern, dict):
                    md.append(f"### {pattern.get('category', 'Pattern')}")
                    md.append("")
                    md.append("```" + pattern.get('language', 'python'))
                    md.append(pattern.get('code', '# Example code'))
                    md.append("```")
                    if pattern.get('description'):
                        md.append(f"_{pattern['description']}_")
                    md.append("")
        else:
            # Infer patterns from artifacts
            scripts = [a for a in artifacts if a.get('type') == 'script']
            if scripts:
                md.append("### Common Operations")
                md.append("")
                md.append("| Task | Command | Notes |")
                md.append("|------|---------|-------|")
                for script in scripts[:5]:
                    script_name = Path(script['filename']).name
                    ext = Path(script['filename']).suffix
                    if ext == '.py':
                        md.append(f"| Run {script_name} | `python3 {script['filename']}` | Execute script |")
                    elif ext == '.sh':
                        md.append(f"| Run {script_name} | `bash {script['filename']}` | Execute script |")
                md.append("")
            else:
                md.append("No code patterns documented in this thread.")
                md.append("")
        md.append("---")
        md.append("")
        
        # STATE SNAPSHOT
        md.append("## State Snapshot")
        md.append("")
        md.append(f"**As of export ({export_date}):**")
        md.append("")
        
        md.append("### File System")
        if artifacts:
            md.append("```")
            by_type = {}
            for a in artifacts:
                atype = a.get('type', 'other')
                by_type.setdefault(atype, []).append(a)
            
            for atype, files in sorted(by_type.items()):
                if len(files) == 1:
                    size_kb = files[0].get('size_bytes', 0) / 1024
                    md.append(f"{files[0]['filename']} ({size_kb:.1f} KB)")
                else:
                    md.append(f"{atype}/")
                    for f in files[:10]:
                        size_kb = f.get('size_bytes', 0) / 1024
                        fname = Path(f['filename']).name
                        md.append(f"├── {fname} ({size_kb:.1f} KB)")
                    if len(files) > 10:
                        md.append(f"└── ... and {len(files) - 10} more")
            md.append("```")
            md.append("")
        else:
            md.append("No file system artifacts.")
            md.append("")
        
        md.append("### Key Metrics")
        artifact_count = telemetry.get('artifacts_created', len(artifacts))
        total_bytes = telemetry.get('total_size_bytes', sum(a.get('size_bytes', 0) for a in artifacts))
        total_mb = total_bytes / (1024 * 1024)
        md.append(f"- **Artifacts created:** {artifact_count}")
        md.append(f"- **Total size:** {total_mb:.2f} MB")
        md.append(f"- **Generation method:** {telemetry.get('aar_generation_method', 'unknown')}")
        md.append("")
        md.append("---")
        md.append("")
        
        # TESTING STATUS
        md.append("## Testing Status")
        md.append("")
        test_status = aar_data.get('testing', {})
        completed_tests = test_status.get('completed', [])
        pending_tests = test_status.get('pending', [])
        failed_tests = test_status.get('failed', [])
        
        if completed_tests or pending_tests or failed_tests:
            if completed_tests:
                md.append("### Completed Tests")
                for test in completed_tests:
                    md.append(f"✅ {test}")
                md.append("")
            
            if pending_tests:
                md.append("### Pending Tests")
                for test in pending_tests:
                    md.append(f"⏳ {test}")
                md.append("")
            
            if failed_tests:
                md.append("### Known Failures")
                for test in failed_tests:
                    md.append(f"❌ {test}")
                md.append("")
        else:
            md.append("No formal testing documented for this thread.")
            md.append("")
            scripts = [a for a in artifacts if a.get('type') == 'script']
            if scripts:
                md.append("### Test Commands")
                md.append("```bash")
                md.append("# Verify scripts exist")
                for script in scripts[:3]:
                    md.append(f"ls -la {script['filename']}")
                md.append("")
                md.append("# Test execution (dry-run if available)")
                for script in scripts[:3]:
                    ext = Path(script['filename']).suffix
                    if ext == '.py':
                        md.append(f"python3 {script['filename']} --help")
                md.append("```")
                md.append("")
        md.append("---")
        md.append("")
        
        # OPEN QUESTIONS
        md.append("## Open Questions")
        md.append("")
        questions = aar_data.get('open_questions', [])
        if questions:
            for i, question in enumerate(questions, 1):
                if isinstance(question, dict):
                    md.append(f"### {i}. {question.get('question', 'Question')}")
                    if question.get('context'):
                        md.append(f"- **Context:** {question['context']}")
                    if question.get('options'):
                        md.append("- **Options:**")
                        for opt in question['options']:
                            md.append(f"  - {opt}")
                    if question.get('blocking'):
                        md.append(f"- **Blocking:** {question['blocking']}")
                    md.append("")
                else:
                    md.append(f"### {i}. {question}")
                    md.append("")
        else:
            md.append("No open questions documented. All decisions have been made for the current scope.")
            md.append("")
        md.append("---")
        md.append("")
        
        # IF STUCK, CHECK THESE
        md.append("## If Stuck, Check These")
        md.append("")
        troubleshooting = aar_data.get('troubleshooting', [])
        if troubleshooting:
            for item in troubleshooting:
                if isinstance(item, dict):
                    md.append(f"### Problem: {item.get('problem', 'Issue')}")
                    md.append("**Check:**")
                    for check in item.get('checks', []):
                        md.append(f"- {check}")
                    if item.get('solution'):
                        md.append(f"\n**Solution:** {item['solution']}")
                    md.append("")
        else:
            md.append("### General Debugging Steps")
            md.append("")
            md.append("1. **Verify file paths** - Check that all referenced files exist")
            md.append("2. **Check dependencies** - Ensure required packages/modules are installed")
            md.append("3. **Review logs** - Look for error messages or warnings")
            md.append("4. **Test incrementally** - Isolate the failing component")
            scripts = [a for a in artifacts if a.get('type') == 'script']
            if scripts:
                md.append("")
                md.append("### Script-Specific Checks")
                md.append("```bash")
                md.append("# Verify scripts are executable")
                for script in scripts[:3]:
                    md.append(f"python3 -m py_compile {script['filename']} 2>&1")
                md.append("```")
            md.append("")
        md.append("---")
        md.append("")
        
        # SYSTEM ARCHITECTURE CONTEXT
        md.append("## System Architecture Context")
        md.append("")
        architecture = aar_data.get('architecture', {})
        if architecture:
            if architecture.get('description'):
                md.append(f"{architecture['description']}")
                md.append("")
            if architecture.get('diagram'):
                md.append("```")
                md.append(architecture['diagram'])
                md.append("```")
                md.append("")
        else:
            md.append("### Where This Fits")
            md.append("")
            md.append("This work represents a discrete conversation session. For broader system context:")
            md.append("")
            md.append("- Review related threads in `N5/logs/threads/`")
            md.append("- Check integration points in code/documentation")
            md.append("- Consider dependencies on external systems")
            md.append("")
        
        if artifacts:
            md.append("### Artifacts by Type")
            md.append("")
            by_type = {}
            for a in artifacts:
                atype = a.get('type', 'other')
                by_type.setdefault(atype, []).append(a)
            
            for atype, items in sorted(by_type.items()):
                md.append(f"- **{atype.capitalize()}**: {len(items)} file(s)")
            md.append("")
        md.append("---")
        md.append("")
        
        # ASSUMPTIONS & VALIDATIONS
        md.append("## Assumptions & Validations")
        md.append("")
        assumptions = aar_data.get('assumptions', [])
        if assumptions:
            md.append("**Assumed to be TRUE (verify if resuming):**")
            for assumption in assumptions:
                if isinstance(assumption, dict):
                    md.append(f"- [ ] {assumption.get('statement', 'Assumption')}")
                else:
                    md.append(f"- [ ] {assumption}")
            md.append("")
        else:
            md.append("**Assumed to be TRUE (verify if resuming after time gap):**")
            md.append("- [ ] File structure remains unchanged")
            md.append("- [ ] Dependencies are still installed")
            md.append("- [ ] External services/APIs remain available")
            md.append("")
        
        md.append("**Quick validation commands:**")
        md.append("```bash")
        if artifacts:
            md.append("# Verify artifacts exist")
            for artifact in artifacts[:5]:
                md.append(f"test -f {artifact['filename']} && echo '✓ {Path(artifact['filename']).name}' || echo '✗ MISSING'")
        else:
            md.append("# No artifacts to validate")
        md.append("```")
        md.append("")
        md.append("---")
        md.append("")
        
        # USER PREFERENCES (V'S STYLE)
        md.append("## User Preferences (V's Style)")
        md.append("")
        user_prefs = aar_data.get('user_preferences', {})
        if user_prefs:
            for category, prefs in user_prefs.items():
                md.append(f"### {category}")
                for pref in prefs:
                    md.append(f"- {pref}")
                md.append("")
        else:
            md.append("### Code Style")
            md.append("- ✅ Use pathlib.Path, not os.path")
            md.append("- ✅ Type hints in function signatures")
            md.append("- ✅ Docstrings for public functions")
            md.append("- ✅ Explicit better than implicit")
            md.append("")
            md.append("### Error Handling")
            md.append("- ✅ Specific try/except with recovery")
            md.append("- ✅ Clear error messages with context")
            md.append("- ❌ Don't silently swallow exceptions")
            md.append("")
            md.append("### Testing Approach")
            md.append("- ✅ Dry-run mode for destructive operations")
            md.append("- ✅ Validation before writes")
            md.append("- ✅ Manual smoke tests before automation")
            md.append("")
        md.append("---")
        md.append("")
        
        # FILES CREATED/MODIFIED
        md.append("## Files Created/Modified")
        md.append("")
        if artifacts:
            md.append("### Created")
            for artifact in artifacts:
                desc = artifact.get('description', f"{artifact.get('type', 'File')} artifact")
                md.append(f"- `{artifact['filename']}` - {desc}")
            md.append("")
        else:
            md.append("No files were created during this conversation.")
            md.append("")
        
        modifications = aar_data.get('modifications', [])
        if modifications:
            md.append("### Modified")
            for mod in modifications:
                if isinstance(mod, dict):
                    md.append(f"- `{mod.get('file', 'unknown')}` - {mod.get('changes', 'Modified')}")
                else:
                    md.append(f"- {mod}")
            md.append("")
        md.append("---")
        md.append("")
        
        # THREAD LINEAGE & RELATED WORK
        md.append("## Thread Lineage & Related Work")
        md.append("")
        lineage = aar_data.get('lineage', {})
        if lineage:
            if lineage.get('previous_threads'):
                md.append("### Previous Related Threads")
                for thread in lineage['previous_threads']:
                    if isinstance(thread, dict):
                        md.append(f"- Thread {thread.get('id', 'unknown')}: {thread.get('topic', 'Related work')}")
                        if thread.get('relationship'):
                            md.append(f"  - Relationship: {thread['relationship']}")
                    else:
                        md.append(f"- {thread}")
                md.append("")
            
            if lineage.get('related_components'):
                md.append("### Related System Components")
                for component in lineage['related_components']:
                    md.append(f"- {component}")
                md.append("")
        else:
            md.append("No explicit thread lineage documented. This may be a standalone conversation.")
            md.append("")
            md.append("### To find related work:")
            md.append("```bash")
            md.append("# Search for related threads by topic")
            md.append("ls -lt N5/logs/threads/ | head -20")
            md.append("")
            md.append("# Search for similar content")
            md.append("grep -r 'relevant keyword' N5/logs/threads/")
            md.append("```")
            md.append("")
        md.append("---")
        md.append("")
        
        # SUCCESS CRITERIA
        md.append("## Success Criteria")
        md.append("")
        success_criteria = aar_data.get('success_criteria', {})
        if success_criteria:
            if success_criteria.get('definition_of_done'):
                md.append("**Definition of Done:**")
                for item in success_criteria['definition_of_done']:
                    status = "x" if item.get('completed') else " "
                    md.append(f"- [{status}] {item.get('criterion', 'Criterion')}")
                md.append("")
            
            if success_criteria.get('acceptance_tests'):
                md.append("**Acceptance Tests:**")
                md.append("```bash")
                for test in success_criteria['acceptance_tests']:
                    md.append(f"# {test.get('description', 'Test')}")
                    md.append(test.get('command', '# command'))
                    md.append("")
                md.append("```")
                md.append("")
        else:
            md.append("**Definition of Done:**")
            if artifacts:
                md.append(f"- [x] {len(artifacts)} artifacts created and verified")
                md.append("- [x] Files saved to conversation workspace")
                scripts = [a for a in artifacts if a.get('type') == 'script']
                if scripts:
                    md.append("- [ ] Scripts tested and validated")
                md.append("- [ ] Work documented in AAR")
            else:
                md.append("- [ ] Objectives achieved (to be defined)")
                md.append("- [ ] Deliverables completed (to be defined)")
            md.append("")
            
            if artifacts:
                md.append("**Acceptance Tests:**")
                md.append("```bash")
                md.append("# Verify all artifacts exist")
                for artifact in artifacts[:3]:
                    md.append(f"test -f {artifact['filename']} && echo 'PASS' || echo 'FAIL'")
                md.append("```")
                md.append("")
        md.append("---")
        md.append("")
        
        # CONTEXT FOR RESUME
        md.append("## Context for Resume")
        md.append("")
        resume_context = aar_data.get('resume_context', {})
        if resume_context:
            md.append(f"**Status:** {resume_context.get('status', 'Ready for continuation')}")
            md.append("")
            if resume_context.get('next_action'):
                md.append(f"**Next Action:** {resume_context['next_action']}")
                md.append("")
            if resume_context.get('blockers'):
                md.append("**Blockers:**")
                for blocker in resume_context['blockers']:
                    md.append(f"- {blocker}")
                md.append("")
        else:
            md.append("**For continuation in a new thread:**")
            md.append("")
            md.append("1. Load this AAR in the new conversation")
            md.append("2. Review 'What Was Completed' and 'Next Steps' sections")
            md.append("3. Verify file state matches expectations")
            md.append("4. Proceed with primary objective")
            md.append("")
            md.append("**Key context to provide:**")
            md.append(f"- Thread ID: {thread_id}")
            md.append(f"- Export date: {export_date}")
            if artifacts:
                md.append(f"- {len(artifacts)} artifacts in conversation workspace")
            md.append("- Current status: Work completed, ready for next phase")
            md.append("")
        md.append("---")
        md.append("")
        
        # RELATED DOCUMENTATION
        md.append("## Related Documentation")
        md.append("")
        related_docs = aar_data.get('related_documentation', [])
        if related_docs:
            for doc in related_docs:
                if isinstance(doc, dict):
                    md.append(f"- **{doc.get('title', 'Document')}**: `file '{doc.get('path', 'unknown')}'`")
                    if doc.get('description'):
                        md.append(f"  - {doc['description']}")
                else:
                    md.append(f"- {doc}")
            md.append("")
        else:
            md.append("### Key N5 Documentation")
            md.append("")
            md.append("- `file 'N5/prefs/prefs.md'` - User preferences and conventions")
            md.append("- `file 'N5/schemas/aar.schema.json'` - AAR JSON schema")
            md.append("- `file 'N5/prefs/threads/thread-export-format.md'` - Thread export specification")
            md.append("- `file 'Documents/N5.md'` - N5 system overview")
            md.append("")
            docs_in_artifacts = [a for a in artifacts if a.get('type') == 'document']
            if docs_in_artifacts:
                md.append("### Documentation Created in This Thread")
                for doc in docs_in_artifacts:
                    md.append(f"- `file '{doc['filename']}'`")
                md.append("")
        md.append("---")
        md.append("")
        
        # EXPORT METADATA
        md.append("## Export Metadata")
        md.append("")
        metadata = aar_data.get('metadata', {})
        md.append(f"- **AAR Version:** {aar_data.get('aar_version', AAR_VERSION)}")
        md.append(f"- **Thread ID:** {thread_id}")
        md.append(f"- **Export Date:** {export_date}")
        md.append(f"- **Generated By:** {telemetry.get('aar_generated_by', 'N5 Thread Export System')}")
        md.append(f"- **Generation Method:** {telemetry.get('aar_generation_method', 'unknown')}")
        if metadata.get('ended_at'):
            md.append(f"- **Thread Ended:** {metadata['ended_at']}")
        md.append(f"- **Artifacts Count:** {telemetry.get('artifacts_created', len(artifacts))}")
        total_bytes = telemetry.get('total_size_bytes', 0)
        md.append(f"- **Total Size:** {total_bytes:,} bytes ({total_bytes / 1024:.1f} KB)")
        md.append("")
        md.append("---")
        md.append("")
        md.append("**End of AAR** — Generated by N5 Thread Export System v2.0")
        md.append("")
        
        # Return joined markdown
        return '\n'.join(md)
    
    def copy_artifacts(self):
        """Copy artifacts from conversation workspace to archive"""
        if not self.artifacts:
            print("  No artifacts to copy")
            return
        
        self.artifacts_dir.mkdir(parents=True, exist_ok=True)
        
        for artifact in self.artifacts:
            src = artifact['path']
            dest = self.artifacts_dir / artifact['relative_path']
            dest.parent.mkdir(parents=True, exist_ok=True)
            
            if not self.dry_run:
                shutil.copy2(src, dest)
            print(f"  {'[DRY-RUN]' if self.dry_run else '✓'} Copied: {artifact['filename']}")
    
    def discover_artifacts(self):
        """Wrapper method for inventory_artifacts"""
        self.artifacts = self.inventory_artifacts()
    
    def generate_interactive_aar(self) -> Dict:
        """Generate AAR through interactive questions"""
        responses = self.ask_interactive_questions()
        return self.generate_aar_data(responses)
    
    def generate_dummy_aar(self) -> Dict:
        """Generate minimal AAR with dummy data for testing"""
        dummy_responses = {
            'objective': 'Thread objective (to be filled interactively)',
            'decisions': ['Decision 1 (to be filled)', 'Decision 2 (to be filled)'],
            'outcomes': 'Outcomes (to be filled interactively)',
            'next_objective': 'Next objective (to be filled interactively)',
            'challenges': ''
        }
        return self.generate_aar_data(dummy_responses)
    
    # ===== PHASE 3: SMART CONTENT EXTRACTION =====
    
    def detect_conversation_type(self) -> str:
        """Detect conversation type from artifacts and title"""
        if not self.artifacts:
            return "general"
        
        title_lower = (self.title or "").lower()
        
        # Count artifact types
        scripts = [a for a in self.artifacts if a['type'] == 'script']
        docs = [a for a in self.artifacts if a['type'] == 'document']
        data_files = [a for a in self.artifacts if a['type'] == 'data']
        
        # Bug fix indicators
        if any(x in title_lower for x in ['bug', 'fix', 'debug', 'error']):
            return "bugfix"
        
        # Implementation indicators
        if len(scripts) >= 2 and any('test' in a['filename'].lower() for a in self.artifacts):
            return "implementation"
        
        # Research indicators  
        if len(docs) > len(scripts) and len(docs) >= 3:
            return "research"
        
        # Data analysis indicators
        if len(data_files) >= 2 and any(x in title_lower for x in ['analysis', 'report', 'data']):
            return "analysis"
        
        # Strategy/planning indicators
        if any(x in title_lower for x in ['strategy', 'plan', 'design', 'architecture']):
            return "strategy"
        
        return "general"
    
    def extract_objective_from_artifacts(self) -> str:
        """Infer conversation objective from artifacts and patterns"""
        if not self.artifacts:
            return "Work session with no artifacts created"
        
        conv_type = self.detect_conversation_type()
        title = self.title or "conversation"
        
        # Type-specific objective templates
        if conv_type == "implementation":
            script_count = len([a for a in self.artifacts if a['type'] == 'script'])
            return f"Implement {title} with {script_count} script(s) and supporting artifacts"
        
        elif conv_type == "research":
            doc_count = len([a for a in self.artifacts if a['type'] == 'document'])
            return f"Research and document findings on {title} ({doc_count} documents created)"
        
        elif conv_type == "bugfix":
            return f"Debug and fix issue: {title}"
        
        elif conv_type == "analysis":
            return f"Analyze data and generate insights for {title}"
        
        elif conv_type == "strategy":
            return f"Strategic planning and decision-making for {title}"
        
        else:
            # Generic objective based on artifacts
            artifact_types = set(a['type'] for a in self.artifacts)
            types_str = ", ".join(artifact_types)
            return f"Create and organize {types_str} artifacts for {title}"
    
    def extract_key_decisions(self) -> List[str]:
        """Extract key decisions from artifact analysis"""
        decisions = []
        conv_type = self.detect_conversation_type()
        
        # Decision 1: Conversation type/approach
        type_descriptions = {
            "implementation": "Chose implementation approach with scripts and testing",
            "research": "Conducted research-based exploration with documentation",
            "bugfix": "Diagnosed and implemented bug fix",
            "analysis": "Performed data analysis with structured outputs",
            "strategy": "Developed strategic plan with decision framework",
            "general": "Completed work session"
        }
        decisions.append(type_descriptions.get(conv_type, "Completed work session"))
        
        # Decision 2: File organization pattern
        if len(self.artifacts) > 5:
            decisions.append(f"Organized work into {len(self.artifacts)} discrete artifacts")
        elif len(self.artifacts) > 0:
            decisions.append(f"Created focused set of {len(self.artifacts)} artifact(s)")
        
        # Decision 3: Technology/tools (if scripts present)
        scripts = [a for a in self.artifacts if a['type'] == 'script']
        if scripts:
            extensions = set(Path(a['filename']).suffix for a in scripts)
            tech = {'.py': 'Python', '.sh': 'Bash', '.js': 'JavaScript', '.ts': 'TypeScript'}
            techs = [tech.get(ext, ext) for ext in extensions if ext in tech]
            if techs:
                decisions.append(f"Used {', '.join(techs)} for implementation")
        
        return decisions[:3]  # Limit to 3 key decisions
    
    def generate_smart_summary(self) -> str:
        """Generate intelligent outcome summary from artifacts"""
        if not self.artifacts:
            return "Conversation completed with no artifacts generated"
        
        conv_type = self.detect_conversation_type()
        artifact_count = len(self.artifacts)
        total_size = sum(a['size_bytes'] for a in self.artifacts)
        size_kb = total_size / 1024
        
        # Group artifacts by type
        by_type = {}
        for a in self.artifacts:
            by_type.setdefault(a['type'], []).append(a)
        
        type_summary = ", ".join(f"{len(v)} {k}(s)" for k, v in by_type.items())
        
        # Type-specific summaries
        if conv_type == "implementation":
            return f"Completed implementation with {type_summary} totaling {size_kb:.1f}KB. System ready for testing."
        
        elif conv_type == "research":
            return f"Research completed with {type_summary}. Documentation captures findings and insights."
        
        elif conv_type == "bugfix":
            return f"Bug fix implemented and documented with {type_summary}."
        
        elif conv_type == "analysis":
            return f"Analysis completed with {type_summary} containing results and visualizations."
        
        else:
            return f"Created {artifact_count} artifacts ({type_summary}) totaling {size_kb:.1f}KB"
    
    def infer_next_steps(self) -> str:
        """Infer logical next steps based on conversation type and artifacts"""
        conv_type = self.detect_conversation_type()
        
        # Type-specific next steps
        next_steps = {
            "implementation": "Test implementation, integrate with existing systems, document usage",
            "research": "Review findings, share with stakeholders, determine action items",
            "bugfix": "Verify fix works, deploy to production, add regression tests",
            "analysis": "Review analysis results, make data-driven decisions, create action plan",
            "strategy": "Execute strategic plan, assign responsibilities, set milestones",
            "general": "Review work completed, determine next priorities"
        }
        
        return next_steps.get(conv_type, "Continue development based on session outcomes")
    
    def generate_smart_aar(self) -> Dict:
        """Generate intelligent AAR using content extraction (Phase 3)"""
        smart_responses = {
            'objective': self.extract_objective_from_artifacts(),
            'decisions': self.extract_key_decisions(),
            'outcomes': self.generate_smart_summary(),
            'next_objective': self.infer_next_steps(),
            'challenges': ''  # No way to infer challenges programmatically yet
        }
        
        aar = self.generate_aar_data(smart_responses)
        # Mark as smart-generated
        aar['telemetry']['aar_generation_method'] = 'smart_extraction'
        return aar
    
    # ===== PHASE 3B: PROGRESSIVE DOCUMENTATION =====
    
    def save_checkpoint(self):
        """Save progressive AAR checkpoint (draft)"""
        self.archive_dir.mkdir(parents=True, exist_ok=True)
        
        if not self.dry_run:
            with open(self.checkpoint_path, 'w', encoding='utf-8') as f:
                json.dump(self.aar_data, f, indent=2, ensure_ascii=False)
        
        print(f"  {'[DRY-RUN]' if self.dry_run else '✓'} Saved checkpoint: {self.checkpoint_path.name}")
        return self.checkpoint_path
    
    def load_latest_checkpoint(self) -> Optional[Dict]:
        """Load most recent checkpoint for this thread"""
        if not self.archive_dir.exists():
            return None
        
        # Find all checkpoint files
        checkpoints = sorted(self.archive_dir.glob("checkpoint-*.json"))
        if not checkpoints:
            return None
        
        latest = checkpoints[-1]
        print(f"  Loading checkpoint: {latest.name}")
        
        with open(latest, 'r', encoding='utf-8') as f:
            return json.load(f)
    
    def merge_checkpoint_data(self, checkpoint: Dict) -> Dict:
        """Merge checkpoint data with current session"""
        # Start with current smart extraction
        current = self.generate_smart_aar()
        
        # Merge key events (combine lists, dedupe)
        checkpoint_events = checkpoint.get('key_events', [])
        current_events = current.get('key_events', [])
        
        # Merge artifacts (use current, as it's fresher)
        # But preserve checkpoint's executive summary if more detailed
        if len(checkpoint['executive_summary']['purpose']) > len(current['executive_summary']['purpose']):
            current['executive_summary'] = checkpoint['executive_summary']
        
        # Combine key events
        all_events = checkpoint_events + current_events
        current['key_events'] = all_events[:20]  # Limit to schema max
        
        return current
    
    def save_aar(self, aar_data: Dict, markdown: str):
        """Save AAR in both JSON and Markdown formats (dual-write)"""
        self.archive_dir.mkdir(parents=True, exist_ok=True)
        
        # Write JSON (source of truth)
        if not self.dry_run:
            with open(self.aar_json_path, 'w', encoding='utf-8') as f:
                json.dump(aar_data, f, indent=2, ensure_ascii=False)
        print(f"  {'[DRY-RUN]' if self.dry_run else '✓'} Saved JSON: {self.aar_json_path}")
        
        # Write Markdown (generated view)
        if not self.dry_run:
            with open(self.aar_md_path, 'w', encoding='utf-8') as f:
                f.write(markdown)
        print(f"  {'[DRY-RUN]' if self.dry_run else '✓'} Saved Markdown: {self.aar_md_path}")
    
    def run(self, interactive=True):
        """Execute full AAR export workflow"""
        
        print("\n" + "="*70)
        print(f"Thread Export: {self.thread_id}")
        print("="*70)
        
        # Inventory artifacts
        print("\nPhase 1: Inventory Artifacts")
        self.discover_artifacts()
        print(f"  Found {len(self.artifacts)} artifacts in conversation workspace")
        
        # Detect conversation type for smart extraction
        if not interactive:
            conv_type = self.detect_conversation_type()
            print(f"  Detected conversation type: {conv_type}")
        
        # Generate AAR data
        if interactive:
            print("\nPhase 2: Interactive AAR Generation")
            self.aar_data = self.generate_interactive_aar()
        else:
            print("\nPhase 2: Smart AAR Generation (Content Extraction)")
            if self.dry_run:
                print("  [DRY-RUN] Preview mode - using smart extraction")
            self.aar_data = self.generate_smart_aar()
        
        print("\nPhase 3: Validate AAR Data")
        valid, errors = self.validate_aar(self.aar_data)
        if not valid:
            print("  ⚠️  Validation warnings:")
            for error in errors:
                print(f"    {error}")
        else:
            print("  ✓ AAR validated against schema")
        
        markdown = self.generate_markdown(self.aar_data)
        
        # Preview
        print("\nPhase 4: Archive Structure")
        print(f"  Archive directory: {self.archive_dir}")
        print(f"  AAR JSON: {self.aar_json_path.name}")
        print(f"  AAR Markdown: {self.aar_md_path.name}")
        print(f"  Artifacts: {len(self.artifacts)} files → artifacts/")
        
        # Dry-run check
        if self.dry_run:
            print("\n[DRY-RUN MODE] - No files will be written")
            print("\nAAR Preview (first 1000 chars):")
            print("-" * 70)
            print(markdown[:1000])
            print("-" * 70)
            return True
        
        # Confirm (unless auto-confirmed)
        if not self.auto_confirm:
            print("\nReady to create archive. Proceed? (y/n): ", end='')
            if input().lower() != 'y':
                print("Cancelled.")
                return False
        
        # Execute
        print("\nPhase 5: Create Archive")
        self.save_aar(self.aar_data, markdown)
        self.copy_artifacts()
        
        print(f"\n✅ AAR Export Complete!")
        print(f"   Archive: {self.archive_dir}")
        
        return True


def main():
    parser = argparse.ArgumentParser(
        description="Generate After-Action Report (AAR) for conversation threads",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    parser.add_argument(
        "thread_id",
        nargs='?',
        help="Thread ID (e.g., con_mZrkGmXndDPiWtMR)"
    )
    parser.add_argument(
        "--title",
        help="Descriptive title for the thread (used in archive directory name)"
    )
    parser.add_argument(
        "--auto",
        action="store_true",
        help="Auto-detect current thread from most recently modified workspace"
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Preview without creating files"
    )
    parser.add_argument(
        "--non-interactive",
        action="store_true",
        help="Skip interactive questions (use artifact data only)"
    )
    parser.add_argument(
        "--yes",
        action="store_true",
        help="Auto-confirm all prompts (for automated execution)"
    )
    
    args = parser.parse_args()
    
    # Determine thread ID
    thread_id = args.thread_id
    if args.auto or not thread_id:
        print("Auto-detecting current thread...")
        exporter = ThreadExporter("dummy")
        thread_id = exporter.detect_thread_id()
        if not thread_id:
            print("❌ Could not detect thread ID. Please specify manually.")
            sys.exit(1)
        print(f"  Detected: {thread_id}")
    
    # Validate thread ID format
    if not thread_id.startswith("con_") or len(thread_id) != 20:
        print(f"❌ Invalid thread ID format: {thread_id}")
        print("   Expected: con_[16 characters]")
        sys.exit(1)
    
    # Ask for title if not provided (unless auto-confirmed)
    title = args.title
    if not title and not args.dry_run and not args.yes:
        print("\nProvide a descriptive title for this thread:")
        print("(This will be used in the archive directory name)")
        title = input("Title: ").strip()
    elif not title and args.yes:
        # Generate default title for automated execution
        title = f"conversation-{datetime.now().strftime('%Y%m%d-%H%M%S')}"
    
    # Run export
    exporter = ThreadExporter(thread_id, title, args.dry_run)
    exporter.auto_confirm = args.yes  # Set auto-confirm flag
    success = exporter.run(interactive=not args.non_interactive and not args.yes)
    
    sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()
