{
  "dashboard": {
    "title": "N5 System Health",
    "tags": ["n5os", "health"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "System Health Overview",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 24, "h": 4},
        "targets": [
          {
            "expr": "n5_records_staging_count",
            "legendFormat": "Files in Staging"
          },
          {
            "expr": "n5_records_stale_count",
            "legendFormat": "Stale Files (>7d)"
          },
          {
            "expr": "n5_empty_files_count",
            "legendFormat": "Empty Files"
          },
          {
            "expr": "n5_uncommitted_count",
            "legendFormat": "Uncommitted Changes"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Records Flow (Staging → Knowledge)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "n5_records_staging_count",
            "legendFormat": "Staging Count"
          },
          {
            "expr": "n5_knowledge_files_total",
            "legendFormat": "Knowledge Total"
          }
        ]
      },
      {
        "id": 3,
        "title": "Principle Adherence Score",
        "type": "gauge",
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "100 - (n5_empty_files_count + n5_uncommitted_count + (n5_readme_duplication / 10))",
            "legendFormat": "Adherence Score"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 50, "color": "yellow"},
                {"value": 80, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Stale Files Trend",
        "type": "graph",
        "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "n5_records_stale_count",
            "legendFormat": "Stale Files"
          }
        ]
      },
      {
        "id": 5,
        "title": "Script Complexity",
        "type": "stat",
        "gridPos": {"x": 12, "y": 12, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "n5_script_complexity_avg",
            "legendFormat": "Avg LOC/Script"
          },
          {
            "expr": "n5_script_count_total",
            "legendFormat": "Total Scripts"
          }
        ]
      },
      {
        "id": 6,
        "title": "Command Invocations (24h)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 18, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "rate(n5_command_invocations_total[24h])",
            "legendFormat": "{{command}} ({{status}})"
          }
        ]
      }
    ],
    "refresh": "1m",
    "time": {"from": "now-24h", "to": "now"}
  }
}
