{
  "version": "1.0",
  "ats_systems": [
    "ashby",
    "greenhouse",
    "lever",
    "workday",
    "smartrecruiters",
    "apple"
  ],
  "rate_limits": {
    "ashby": {
      "requests_per_minute": 60
    },
    "greenhouse": {
      "requests_per_minute": 100
    },
    "lever": {
      "requests_per_minute": 120
    },
    "workday": {
      "requests_per_minute": 60
    },
    "smartrecruiters": {
      "requests_per_minute": 60
    },
    "apple": {
      "requests_per_minute": 30
    }
  },
  "output_formats": [
    "jsonl",
    "json"
  ],
  "max_retries": 3,
  "timeout_seconds": 10,
  "batch_size": 50
}