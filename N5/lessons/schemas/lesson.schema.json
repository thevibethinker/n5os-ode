{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "N5 Lesson",
  "description": "Captured technique, strategy, pattern, or troubleshooting lesson from a conversation thread",
  "type": "object",
  "required": [
    "lesson_id",
    "thread_id",
    "timestamp",
    "type",
    "title",
    "description",
    "status"
  ],
  "properties": {
    "lesson_id": {
      "type": "string",
      "description": "Unique identifier (UUID)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "thread_id": {
      "type": "string",
      "description": "Conversation thread identifier",
      "pattern": "^con_[A-Za-z0-9]+$"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "format": "date-time"
    },
    "type": {
      "type": "string",
      "enum": [
        "technique",
        "strategy",
        "design_pattern",
        "troubleshooting",
        "anti_pattern"
      ],
      "description": "Category of lesson learned"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 100,
      "description": "Brief, descriptive title"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "What we did or encountered"
    },
    "context": {
      "type": "string",
      "description": "Why it was needed, what led to this"
    },
    "outcome": {
      "type": "string",
      "description": "Result or resolution achieved"
    },
    "principle_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]{1,2}$"
      },
      "description": "References to architectural principles (e.g., ['15', '16'])"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Searchable tags (e.g., error-handling, state-verification)"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "description": "Review status"
    },
    "reviewer_notes": {
      "type": "string",
      "description": "Notes from weekly review"
    }
  }
}
