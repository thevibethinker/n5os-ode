#!/usr/bin/env python3
"""
Command Structure Generator Module for N5 Command Authoring System

Generates structured command representations from scoped drafts.
"""

from typing import Dict, Any
import uuid
from datetime import datetime

def generate_command_structure(scoped_draft: Dict[str, Any]) -> Dict[str, Any]:
    """
    Generate structured command from scoped draft.

    Args:
        scoped_draft: Scoped draft with steps and clarification

    Returns:
        Structured command representation
    """
    if 'error' in scoped_draft:
        return {'error': scoped_draft['error']}

    original_segments = scoped_draft.get('original_segments', [])
    scoped_steps = scoped_draft.get('scoped_steps', [])

    if not scoped_steps:
        return {'error': 'No scoped steps provided'}

    # Extract command name from segments
    command_name = "unknown_command"
    for segment in original_segments:
        content = segment.get('content', '').lower()
        if 'essential-links-add' in content:
            command_name = 'essential-links-add'
            break
        elif 'command' in content:
            # Extract command name
            import re
            match = re.search(r'create\s+(\S+)', content)
            if match:
                command_name = match.group(1).replace('-', '_')

    # Generate command structure
    command_structure = {
        'id': str(uuid.uuid4()),
        'command': command_name,
        'version': '1.0.0',
        'created_at': datetime.utcnow().isoformat() + 'Z',
        'source': 'command_authoring_system',
        'description': f"Generated command: {command_name}",
        'steps': [],
        'retries': {'global_retries': 1},
        'timeout': 60,
        'metadata': {
            'generation_method': 'llm_scoped',
            'confidence': scoped_draft.get('confidence', 0),
            'original_segments_count': len(original_segments)
        }
    }

    # Convert scoped steps to command steps
    for i, step in enumerate(scoped_steps, 1):
        command_step = {
            'id': i,
            'name': f"step_{i}_{step.get('type', 'action')}",
            'description': step.get('description', ''),
            'type': step.get('type', 'action'),
            'action': 'execute',
            'details': step.get('details', [])
        }
        command_structure['steps'].append(command_step)

    return command_structure