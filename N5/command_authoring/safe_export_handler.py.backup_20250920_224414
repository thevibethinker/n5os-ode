#!/usr/bin/env python3
"""
Safe Export Handler Module for N5 Command Authoring System

Safely exports commands to append-only commands.jsonl with backups and integrity checks.
"""

from typing import Dict, Any
from pathlib import Path
import json
import tempfile
import os
import shutil
from datetime import datetime

def safe_export_command(command: Dict[str, Any], commands_file: str) -> Dict[str, Any]:
    """
    Safely export command to commands file.

    Args:
        command: Command to export
        commands_file: Target commands file path

    Returns:
        Export operation results
    """
    if 'error' in command:
        return {'success': False, 'error': command['error']}

    export_result = {
        'success': True,
        'command_id': command.get('id', ''),
        'file_path': commands_file,
        'file_size_before': 0,
        'file_size_after': 0,
        'backup_created': False,
        'backup_path': None,
        'redistillation': {'needed': False},
        'error': None
    }

    try:
        commands_path = Path(commands_file)
        commands_path.parent.mkdir(parents=True, exist_ok=True)

        # Get file size before
        if commands_path.exists():
            export_result['file_size_before'] = commands_path.stat().st_size

            # Create backup
            backup_path = commands_path.with_suffix('.bak')
            shutil.copy2(commands_path, backup_path)
            export_result['backup_created'] = True
            export_result['backup_path'] = str(backup_path)

        # Atomic write using temporary file
        with tempfile.NamedTemporaryFile(
            mode='w',
            dir=commands_path.parent,
            delete=False,
            suffix='.tmp'
        ) as temp_file:

            # Copy existing content
            if commands_path.exists():
                with open(commands_path, 'r') as existing_file:
                    for line in existing_file:
                        temp_file.write(line)

            # Append new command
            command_json = json.dumps(command, separators=(',', ':'))
            temp_file.write(command_json + '\n')

            temp_file.flush()
            os.fsync(temp_file.fileno())
            temp_path = temp_file.name

        # Atomic rename
        os.rename(temp_path, commands_path)

        # Update file size after
        export_result['file_size_after'] = commands_path.stat().st_size

    except Exception as e:
        export_result['success'] = False
        export_result['error'] = str(e)

        # Attempt rollback
        if export_result['backup_created'] and export_result['backup_path']:
            try:
                backup_path = Path(export_result['backup_path'])
                if backup_path.exists():
                    shutil.copy2(backup_path, commands_path)
            except Exception:
                pass

    return export_result

def validate_export_integrity(commands_file: Path, command_id: str) -> Dict[str, Any]:
    """
    Validate that command was properly exported and file integrity.

    Args:
        commands_file: Path to commands file
        command_id: ID of command to verify

    Returns:
        Integrity validation results
    """
    validation = {
        'file_exists': False,
        'file_valid': False,
        'command_found': False,
        'total_commands': 0,
        'file_size': 0,
        'error': None
    }

    try:
        if not commands_file.exists():
            return validation

        validation['file_exists'] = True
        validation['file_size'] = commands_file.stat().st_size

        with open(commands_file, 'r') as f:
            lines = f.readlines()

        validation['total_commands'] = len(lines)

        # Validate JSON and find command
        for line in lines:
            line = line.strip()
            if not line:
                continue
            try:
                cmd = json.loads(line)
                if cmd.get('id') == command_id:
                    validation['command_found'] = True
            except json.JSONDecodeError:
                validation['file_valid'] = False
                validation['error'] = 'Invalid JSON in file'
                return validation

        validation['file_valid'] = True

    except Exception as e:
        validation['error'] = str(e)

    return validation