#!/usr/bin/env python3
"""
Validation Enhancement Module for N5 Command Authoring System

Validates and enhances command structures with security and monitoring.
"""

from typing import Dict, Any, List

def validate_and_enhance_command(command: Dict[str, Any]) -> Dict[str, Any]:
    """
    Validate and enhance command structure.

    Args:
        command: Command structure to validate and enhance

    Returns:
        Enhanced command with validation results
    """
    if 'error' in command:
        return command

    validation_results = {
        'status': 'valid',
        'results': {
            'errors': [],
            'warnings': [],
            'enhancements': []
        }
    }

    # Required field validation
    required_fields = ['id', 'command', 'version', 'steps']
    for field in required_fields:
        if field not in command:
            validation_results['results']['errors'].append(f"Missing required field: {field}")
            validation_results['status'] = 'invalid'

    # Command-specific validation for essential-links-add
    if command.get('command') == 'essential-links-add':
        steps = command.get('steps', [])
        if len(steps) < 3:
            validation_results['results']['warnings'].append("Command has fewer steps than expected for essential-links-add")
        validation_results['results']['enhancements'].append("Added essential-links specific validation")

    # Add monitoring and security enhancements
    enhanced_command = command.copy()

    # Add metadata if not present
    if 'metadata' not in enhanced_command:
        enhanced_command['metadata'] = {}

    enhanced_command['metadata']['validation_enhanced'] = True

    # Add security monitoring
    enhanced_command['security'] = {
        'input_validation': True,
        'output_sanitization': True,
        'audit_logging': True
    }

    # Add monitoring
    enhanced_command['monitoring'] = {
        'telemetry_enabled': True,
        'error_tracking': True,
        'performance_metrics': True
    }

    validation_results['results']['enhancements'].extend([
        "Added security monitoring",
        "Added telemetry tracking",
        "Added input validation"
    ])

    return {
        'validation': validation_results,
        **enhanced_command
    }