{"source_type": "idea", "source_id": "better-at-job-worse-at-interviewing", "source_display": "Better at Job = Worse at Interviewing Paradox", "relation": "originated_by", "target_type": "person", "target_id": "vrijen-attawar", "target_display": "Vrijen Attawar", "context_meeting_id": "mtg_2026-01-15-2026-01-15-shivam-desai-and-vrijen-attawar", "evidence": "The better you are at a job, the worse you are at interviewing because you've been fucking employed, because people have not wanted to let you go.", "evolution_type": null}
{"source_type": "idea", "source_id": "better-at-job-worse-at-interviewing", "source_display": "Better at Job = Worse at Interviewing", "relation": "challenges", "target_type": "idea", "target_id": "interview-skill-signals-job-skill", "target_display": "Traditional Interview Validity", "context_meeting_id": "mtg_2026-01-15-2026-01-15-shivam-desai-and-vrijen-attawar", "evidence": "Interview skill and job skill are inversely correlated at the high end. We've built a system that selects for people who are good at *leaving* jobs, not *doing* them.", "evolution_type": null}
