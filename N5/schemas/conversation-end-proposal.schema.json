{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://va.zo.computer/schemas/conversation-end-proposal.schema.json",
  "title": "Conversation-End Proposal Schema",
  "description": "Analysis output from conversation-end analyzer with proposed file actions",
  "type": "object",
  "required": [
    "conversation",
    "analysis",
    "proposed_actions"
  ],
  "properties": {
    "conversation": {
      "type": "object",
      "required": ["id", "proposed_title", "title_source", "workspace_path"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^con_[A-Za-z0-9]{16}$",
          "description": "Conversation thread identifier"
        },
        "proposed_title": {
          "type": "string",
          "minLength": 10,
          "maxLength": 80,
          "description": "Generated conversation title for archiving"
        },
        "title_source": {
          "type": "string",
          "enum": ["session_state", "aar", "file", "fallback"],
          "description": "Source of the proposed title"
        },
        "workspace_path": {
          "type": "string",
          "description": "Absolute path to conversation workspace"
        }
      }
    },
    "analysis": {
      "type": "object",
      "required": ["total_files", "classified", "conflicts", "warnings"],
      "properties": {
        "total_files": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of files scanned"
        },
        "classified": {
          "type": "object",
          "required": ["deliverables", "finals", "temp", "ignore"],
          "properties": {
            "deliverables": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Files to move to user workspace"
            },
            "finals": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Files to archive as final work products"
            },
            "temp": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Temporary files to archive or delete"
            },
            "ignore": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Files to leave in place"
            }
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "description", "affected_files"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["overwrite", "duplicate_destination", "permission", "circular_dependency"],
                "description": "Type of conflict detected"
              },
              "description": {
                "type": "string",
                "description": "Human-readable explanation"
              },
              "affected_files": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Files involved in conflict"
              },
              "severity": {
                "type": "string",
                "enum": ["error", "warning"],
                "default": "error",
                "description": "Whether this blocks execution"
              }
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Non-blocking warnings about analysis"
        }
      }
    },
    "proposed_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_type", "source", "destination", "reason", "confidence"],
        "properties": {
          "action_type": {
            "type": "string",
            "enum": ["move", "archive", "delete", "ignore"],
            "description": "Proposed action for this file"
          },
          "source": {
            "type": "string",
            "description": "Absolute path to source file"
          },
          "destination": {
            "type": "string",
            "description": "Absolute path to destination (or empty for delete/ignore)"
          },
          "reason": {
            "type": "string",
            "minLength": 10,
            "description": "Explanation of why this action is proposed"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Confidence in this classification/routing decision"
          },
          "impacts": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Potential impacts or dependencies"
          }
        }
      }
    }
  }
}
