{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZoBridge Message Schema",
  "type": "object",
  "required": ["message_id", "timestamp", "from", "to", "type", "content"],
  "properties": {
    "message_id": {
      "type": "string",
      "pattern": "^msg_[0-9]+$",
      "description": "Unique message identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "from": {
      "type": "string",
      "enum": ["ParentZo", "ChildZo"],
      "description": "Sending system"
    },
    "to": {
      "type": "string",
      "enum": ["ParentZo", "ChildZo"],
      "description": "Receiving system"
    },
    "thread_id": {
      "type": "string",
      "description": "Optional thread identifier for grouping messages"
    },
    "in_reply_to": {
      "type": "string",
      "description": "Message ID this responds to"
    },
    "type": {
      "type": "string",
      "enum": ["instruction", "question", "proposal", "response", "feedback", "checkpoint"],
      "description": "Message type"
    },
    "content": {
      "type": "object",
      "description": "Message payload - structure varies by type"
    },
    "expects_reply": {
      "type": "boolean",
      "description": "Whether response is expected"
    },
    "notes": {
      "type": "string",
      "description": "Optional context or metadata"
    }
  }
}
