{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://n5.zo/schemas/tally.survey.schema.json",
  "title": "Tally Survey Metadata",
  "description": "Schema for survey metadata stored in Records/Surveys/",
  "type": "object",
  "required": ["form_id", "title", "status", "created"],
  "properties": {
    "form_id": {
      "type": "string",
      "description": "Tally form ID (6 characters)",
      "pattern": "^[A-Za-z0-9]{6}$"
    },
    "title": {
      "type": "string",
      "description": "Survey title",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "description": "Survey status",
      "enum": ["DRAFT", "PUBLISHED", "ARCHIVED", "CLOSED"]
    },
    "created": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "format": "date-time"
    },
    "published": {
      "type": "string",
      "description": "ISO 8601 timestamp when published",
      "format": "date-time"
    },
    "closed": {
      "type": "string",
      "description": "ISO 8601 timestamp when closed",
      "format": "date-time"
    },
    "public_url": {
      "type": "string",
      "description": "Public survey URL",
      "format": "uri",
      "pattern": "^https://tally\\.so/r/[A-Za-z0-9]{6}$"
    },
    "edit_url": {
      "type": "string",
      "description": "Edit URL for form owner",
      "format": "uri",
      "pattern": "^https://tally\\.so/forms/[A-Za-z0-9]{6}/edit$"
    },
    "submissions_count": {
      "type": "integer",
      "description": "Total number of submissions",
      "minimum": 0
    },
    "last_checked": {
      "type": "string",
      "description": "ISO 8601 timestamp of last submission check",
      "format": "date-time"
    },
    "specification": {
      "type": "string",
      "description": "Path to specification file (relative to Records/Surveys/)"
    },
    "purpose": {
      "type": "string",
      "description": "Business purpose of survey",
      "examples": [
        "lead_collection",
        "customer_feedback",
        "event_registration",
        "product_research",
        "satisfaction_tracking"
      ]
    },
    "owner": {
      "type": "string",
      "description": "Survey owner/requestor"
    },
    "tags": {
      "type": "array",
      "description": "Classification tags",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional custom metadata",
      "additionalProperties": true
    }
  }
}
