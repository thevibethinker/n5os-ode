{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n5.local/schemas/promotion-event.schema.json",
  "title": "Promotion Event Schema",
  "description": "Structured metadata for memory promotion events (Relationship Intelligence OS v1.0)",
  "type": "object",
  "required": [
    "promotion_id",
    "meeting_id",
    "block_ids",
    "memory_type",
    "score",
    "tier",
    "status",
    "provenance",
    "confidence"
  ],
  "additionalProperties": false,
  "properties": {
    "promotion_id": {
      "type": "string",
      "description": "Unique promotion identifier",
      "pattern": "^prom_[a-z0-9]{12}$"
    },
    "meeting_id": {
      "type": "string",
      "description": "Source meeting identifier",
      "pattern": "^[a-z0-9]{6}$"
    },
    "block_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Source block identifiers that triggered this promotion"
    },
    "memory_type": {
      "type": "string",
      "enum": [
        "relationship_delta",
        "org_delta", 
        "deliverable_record",
        "intro_opportunity",
        "commitment_action",
        "strategic_insight"
      ],
      "description": "Type of memory being promoted"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Composite promotion score (0-100)"
    },
    "score_breakdown": {
      "type": "object",
      "properties": {
        "strategic_importance": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "description": "Strategic importance score (0-20)"
        },
        "relationship_delta_strength": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "description": "Relationship delta strength (0-20)"
        },
        "commitment_clarity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "description": "Commitment clarity (owner/date/scope) (0-20)"
        },
        "evidence_quality": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15,
          "description": "Evidence quality score (0-15)"
        },
        "novelty": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15,
          "description": "Novelty vs existing memory (0-15)"
        },
        "execution_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "description": "Execution value score (0-10)"
        }
      },
      "additionalProperties": false,
      "description": "Detailed score breakdown by component"
    },
    "tier": {
      "type": "string",
      "enum": ["A", "B", "C"],
      "description": "Promotion tier: A (75-100, auto-promote), B (50-74, review), C (<50, archive)"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "auto_promoted",
        "queued_for_review",
        "manually_approved",
        "archived",
        "failed",
        "duplicate_skipped"
      ],
      "description": "Current promotion status"
    },
    "hard_overrides": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "explicit_promise",
          "intro_opportunity",
          "named_deliverable",
          "strategic_commitment",
          "relationship_escalation"
        ]
      },
      "uniqueItems": true,
      "description": "Hard override conditions that force promotion regardless of score"
    },
    "deduplication": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["new", "similar_found", "duplicate_exact"],
          "description": "Deduplication check result"
        },
        "similar_promotion_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "IDs of similar promotions found"
        },
        "similarity_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Similarity score with closest match (0-1)"
        },
        "checked_at": {
          "type": "string",
          "format": "date-time",
          "description": "When deduplication check was performed"
        }
      },
      "required": ["status"],
      "additionalProperties": false,
      "description": "Deduplication check metadata"
    },
    "memory_writes": {
      "type": "object",
      "properties": {
        "semantic_memory": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pending", "success", "failed", "skipped"]
            },
            "entity_ids": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Entity IDs written to brain.db"
            },
            "error_message": {
              "type": "string",
              "description": "Error message if write failed"
            }
          },
          "required": ["status"],
          "additionalProperties": false
        },
        "graph_edges": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pending", "success", "failed", "skipped"]
            },
            "edge_ids": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Graph edge IDs written"
            },
            "error_message": {
              "type": "string",
              "description": "Error message if write failed"
            }
          },
          "required": ["status"],
          "additionalProperties": false
        },
        "crm_projection": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pending", "success", "failed", "skipped"]
            },
            "profile_ids": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "CRM profile IDs updated"
            },
            "error_message": {
              "type": "string",
              "description": "Error message if write failed"
            }
          },
          "required": ["status"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "description": "Memory write operation results"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When promotion event was created"
    },
    "promoted_at": {
      "type": "string",
      "format": "date-time",
      "description": "When promotion was actually executed"
    },
    "provenance": {
      "type": "object",
      "required": ["conversation_id", "pipeline_run_id"],
      "properties": {
        "conversation_id": {
          "type": "string",
          "description": "Conversation where promotion was triggered"
        },
        "pipeline_run_id": {
          "type": "string",
          "description": "Pipeline run identifier for promotion batch"
        },
        "script_path": {
          "type": "string",
          "description": "Path to script that executed promotion"
        },
        "version": {
          "type": "string",
          "description": "Version of promotion engine used"
        },
        "idempotency_key": {
          "type": "string",
          "description": "Idempotency key for this promotion operation"
        }
      },
      "additionalProperties": false,
      "description": "Promotion execution provenance"
    },
    "confidence": {
      "type": "object",
      "required": ["overall"],
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Overall confidence in promotion decision (0-1)"
        },
        "scoring_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in score accuracy (0-1)"
        },
        "extraction_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in data extraction from blocks (0-1)"
        },
        "deduplication_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in deduplication check (0-1)"
        }
      },
      "additionalProperties": false,
      "description": "Confidence metrics for promotion decision"
    }
  }
}