{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n5.local/schemas/knowledge.facts.schema.json",
  "title": "N5 Knowledge Fact",
  "type": "object",
  "required": ["id", "subject", "predicate", "object"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string"
    },
    "subject": {
      "type": "string",
      "description": "The subject of the fact"
    },
    "predicate": {
      "type": "string",
      "description": "The relationship or predicate"
    },
    "object": {
      "type": "string",
      "description": "The object of the fact"
    },
    "source": {
      "type": "string",
      "description": "Source of the fact"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score (0-1)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}