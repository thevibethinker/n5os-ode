{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://n5os.local/schemas/inbox_analysis.schema.json",
  "title": "Inbox Analysis Log Entry",
  "description": "Schema for inbox file analysis results",
  "type": "object",
  "required": ["timestamp", "file_path", "destination", "confidence", "reasoning", "action"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of analysis"
    },
    "file_path": {
      "type": "string",
      "description": "Path to file in Inbox/"
    },
    "filename": {
      "type": "string",
      "description": "Original filename"
    },
    "size_bytes": {
      "type": "integer",
      "description": "File size in bytes"
    },
    "file_type": {
      "type": "string",
      "description": "MIME type or file extension"
    },
    "destination": {
      "type": "string",
      "description": "Suggested destination path"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score (0.0-1.0)"
    },
    "reasoning": {
      "type": "string",
      "description": "LLM reasoning for classification"
    },
    "action": {
      "type": "string",
      "enum": ["auto_route", "suggest", "manual_only"],
      "description": "Routing action based on confidence"
    },
    "routed": {
      "type": "boolean",
      "description": "Whether file was automatically routed"
    },
    "routed_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When file was routed (if auto_route)"
    },
    "model_used": {
      "type": "string",
      "description": "LLM model used for analysis"
    }
  }
}
