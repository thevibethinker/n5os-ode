{
  "id": "jobs_intake_from_companies",
  "version": "0.2.0",
  "owner": "V",
  "name": "Jobs Intake from Companies",
  "description": "Workflow to ingest jobs from ATS by detecting company ATS and fallback scraping with product role filters.",
  "tags": ["jobs", "scrape", "ats", "product"],
  "triggers": ["cli", "schedule"],
  "inputs": {
    "companies_file": {"type": "string", "description": "Path to companies.txt file"},
    "roles": {"type": "string", "description": "Comma-separated role filters", "default": ""}
  },
  "steps": [
    {
      "name": "jobs-scrape",
      "command": "jobs-scrape",
      "args": ["--companies-file", "$companies_file", "--roles", "$roles"],
      "dry_run": true
    }
  ],
  "policy": {
    "dry_run_required": true,
    "retry_policy": {"max_retries": 3},
    "concurrency": 1,
    "safety": "high"
  },
  "audit": {
    "telemetry": true
  },
  "review_gate": {
    "enabled": true
  }
}