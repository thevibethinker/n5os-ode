{"name":"jobs-scrape","version":"0.1.0","workflow":"single-shot","summary":"Scrape open roles from given company list (TXT file)","args":[{"name":"companies_file","type":"file","desc":"path/to/companies.txt (one per line)"}],"flags":[{"name":"--roles","desc":"comma-separated role filters","required":false},{"name":"--dry-run","desc":"preview only","required":false}],"side_effects":["writes:file medium-protection"],"permissions_required":["none"],"entry_function":"n5.jobs.commands:scrape"}
{"name":"jobs-add","version":"0.1.0","workflow":"single-shot","summary":"Add one-off job to private list","args":[{"name":"job_string","type":"string","desc":"Title@Company [location] [salary]"}],"flags":[{"name":"--dry-run","desc":"preview only","required":false}],"side_effects":["writes:file medium-protection"],"permissions_required":["none"],"entry_function":"n5.jobs.commands:add_oneoff"}
{"name":"jobs-review","version":"0.1.0","workflow":"interactive","summary":"TUI to approve/reject PENDING jobs","args":[],"flags":[],"side_effects":["writes:file medium-protection"],"permissions_required":["none"],"entry_function":"n5.jobs.commands:review"}
{"name":"transcript-ingest","version":"1.0.0","workflow":"batch-processing","summary":"Ingest and process transcripts from files or Google Drive folders","args":[{"name":"transcript_source","type":"string","desc":"Path to transcript file or Google Drive folder ID"}],"flags":[{"name":"--mode","desc":"Processing mode (load|map|tickets|email|full)","required":false,"default":"full"},{"name":"--gdrive","desc":"Enable Google Drive folder processing","required":false},{"name":"--output-dir","desc":"Output directory for processed files","required":false,"default":"/home/workspace/N5/output"},{"name":"--dry-run","desc":"Preview processing without writing files","required":false}],"side_effects":["writes:file medium-protection","reads:external-api"],"permissions_required":["gdrive-access"],"entry_function":"n5.transcript.commands:ingest"}
{"name":"transcript-ingest","version":"1.0.0","workflow":"data","summary":"Ingest and process transcripts from files or Google Drive folders","inputs":[{"name":"transcript_source","type":"string","description":"Path to transcript file or Google Drive folder ID","required":true}],"flags":{"dry_run":true},"side_effects":["writes:file","external:api"],"permissions_required":["external_api"],"examples":["transcript-ingest /path/to/transcript.txt --mode full","transcript-ingest folder_id --gdrive"]}
