      "size_mb": 45,
      "components": [
        "All minimal scripts",
        "Meeting processing",
        "List management",
        "Reflection ingestion",
        "Helper libraries"
      ]
    },
    "scripts_full": {
      "name": "Scripts — Full Suite",
      "required": false,
      "default": false,
      "description": "All 259 scripts (complete implementation)",
      "size_mb": 120,
      "components": [
        "All scripts",
        "Deliverable generation",
        "Email workflows",
