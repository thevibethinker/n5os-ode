{
  "version": "1.0",
  "description": "N5 OS Module Selection",
  "timestamp": "2025-10-26",
  "modules": {
    "core": {
      "name": "Core Foundation",
      "required": true,
      "description": "Preferences architecture, schemas, command registry (required)",
      "size_mb": 5,
      "components": [
        "prefs/ (modular preferences)",
        "schemas/ (validation schemas)",
        "config/ (command registry, incantum triggers)",
        "commands/ (command documentation)"
      ]
    },
    "lists": {
      "name": "List Management System",
      "required": false,
      "default": true,
      "description": "JSONL-based list system with POLICY, schemas, and structure",
      "size_mb": 2,
      "components": [
        "Lists/POLICY.md",
        "Lists/schemas/",
        "Empty JSONL templates"
      ]
    },
    "meetings": {
      "name": "Meeting Ingestion Workflows",
      "required": false,
      "default": true,
      "description": "Meeting processing protocols, templates, and integration",
      "size_mb": 3,
      "components": [
        "Meeting workflow protocols",
        "Processing templates",
        "Output schemas"
      ]
    },
    "knowledge": {
      "name": "Knowledge Base Reference",
      "required": false,
      "default": false,
      "description": "Architectural principles, glossary, bio (reference only)",
      "size_mb": 4,
      "components": [
        "Architectural principles",
        "Glossary",
        "Bio and company info",
        "Operational principles"
      ]
    },
    "scripts_minimal": {
      "name": "Scripts — Minimal",
      "required": false,
      "default": false,
      "description": "Core utilities only (index, git, audit, conversion)",
