{
  "accuracy_requirements": {
    "doc": {
      "level": "extremely_high",
      "checks": [
        "No placeholders (TODO, TBD, PLACEHOLDER)",
        "No invented facts or hallucinations",
        "All claims must be verifiable",
        "Dates and numbers must be accurate",
        "Citations required for external claims",
        "Internal consistency enforced"
      ],
      "failure_mode": "reject_and_flag"
    },
    "email": {
      "level": "high",
      "checks": [
        "Factual accuracy on commitments",
        "Correct names and roles",
        "Accurate timeline information",
        "No false promises"
      ],
      "failure_mode": "warn_and_review"
    },
    "blog": {
      "level": "high",
      "checks": [
        "Verifiable claims",
        "Appropriate citations",
        "No misleading statements",
        "Brand voice consistency"
      ],
      "failure_mode": "warn_and_review"
    },
    "social": {
      "level": "medium_high",
      "checks": [
        "No false claims",
        "Brand-safe language",
        "Appropriate tone",
        "No controversial errors"
      ],
      "failure_mode": "flag_for_review"
    },
    "note": {
      "level": "medium",
      "checks": [
        "Internal use only",
        "Basic accuracy",
        "No critical errors"
      ],
      "failure_mode": "log_only"
    }
  },
  "voice_consistency": {
    "required_checks": [
      "Profile attributes applied",
      "Structure rules followed",
      "Voice markers present",
      "Avoidance rules respected"
    ],
    "scoring": {
      "excellent": 0.90,
      "good": 0.75,
      "acceptable": 0.60,
      "poor": 0.40
    }
  },
  "structural_requirements": {
    "email": {
      "max_paragraphs": 8,
      "min_words": 30,
      "max_words": 400,
      "required_elements": ["greeting", "purpose", "next_step"]
    },
    "blog": {
      "min_paragraphs": 4,
      "min_words": 300,
      "max_words": 2000,
      "required_elements": ["hook", "body", "conclusion"]
    },
    "social": {
      "max_paragraphs": 12,
      "min_words": 50,
      "max_words": 400,
      "required_elements": ["hook", "value"]
    },
    "doc": {
      "min_paragraphs": 2,
      "min_words": 100,
      "required_elements": ["clear_structure", "complete_information"]
    },
    "note": {
      "flexible": true
    }
  },
  "hybrid_requirements": {
    "description": "Use hybrid voice structure everywhere",
    "implementation": [
      "v2.0 prose quality (natural language)",
      "v1.0 structural optimization (white space, sections)",
      "Strategic section breaks (horizontal rules)",
      "Algorithmic considerations without sacrificing authenticity"
    ]
  },
  "validation_process": [
    "1. Check accuracy requirements for content type",
    "2. Validate voice consistency against profile",
    "3. Verify structural requirements met",
    "4. Confirm hybrid approach applied",
    "5. Run type-specific validation",
    "6. Calculate overall quality score",
    "7. Flag if below threshold"
  ],
  "quality_thresholds": {
    "doc": 0.90,
    "email": 0.80,
    "blog": 0.80,
    "social": 0.75,
    "note": 0.60
  }
}
