Meeting Monitor System: {
  shape: rectangle
  style.stroke: "#2563eb"
  style.stroke-width: 3
  
  Scheduled Task: {
    shape: document
    style.stroke: "#059669"
    style.stroke-width: 2
    label: "Every 15 min\n96 cycles/day"
  }
  
  APIs: {
    style.stroke: "#7c3aed"
    style.stroke-width: 2
    
    Calendar API: {
      shape: cylinder
      style.stroke: "#7c3aed"
      label: "Google Calendar\nREAD ONLY"
    }
    
    Gmail API: {
      shape: cylinder
      style.stroke: "#7c3aed"
      label: "Gmail\nREAD ONLY"
    }
  }
  
  Core Components: {
    style.stroke: "#dc2626"
    style.stroke-width: 2
    
    Monitor: {
      shape: hexagon
      style.stroke: "#dc2626"
      label: "meeting_monitor.py\nOrchestrator"
    }
    
    Processor: {
      shape: rectangle
      style.stroke: "#dc2626"
      label: "meeting_processor.py\nBusiness Logic"
    }
    
    API Layer: {
      shape: rectangle
      style.stroke: "#dc2626"
      label: "meeting_api_integrator.py\nAPI Calls"
    }
    
    State: {
      shape: rectangle
      style.stroke: "#dc2626"
      label: "meeting_state_manager.py\nDuplicate Prevention"
    }
    
    Profiles: {
      shape: rectangle
      style.stroke: "#dc2626"
      label: "stakeholder_profile_manager.py\nProfile CRUD"
    }
  }
  
  Data Stores: {
    style.stroke: "#059669"
    style.stroke-width: 2
    
    Log File: {
      shape: document
      style.stroke: "#059669"
      label: "meeting_monitor.log\nAppend only"
    }
    
    State File: {
      shape: stored_data
      style.stroke: "#059669"
      label: ".processed.json\nAtomic writes"
    }
    
    Profile Dirs: {
      shape: package
      style.stroke: "#059669"
      label: "meetings/\n{date}-{name}/\nprofile.md"
    }
  }
  
  Integrations: {
    style.stroke: "#f59e0b"
    style.stroke-width: 2
    
    Meeting Prep: {
      shape: document
      style.stroke: "#f59e0b"
      label: "Daily Meeting Prep\n(10 AM)"
    }
    
    Transcript Proc: {
      shape: document
      style.stroke: "#f59e0b"
      label: "Transcript Processing\n(every 10 min)"
    }
    
    CRM: {
      shape: cylinder
      style.stroke: "#f59e0b"
      label: "CRM Database\n(NOT INTEGRATED)"
    }
    
    Lists: {
      shape: package
      style.stroke: "#f59e0b"
      label: "Lists System\n(OPPORTUNITY)"
    }
  }
}

Scheduled Task -> APIs.Calendar API: "Fetch events\n(7 days)"
Scheduled Task -> APIs.Gmail API: "Search emails\nfor context"

APIs.Calendar API -> Core Components.API Layer
APIs.Gmail API -> Core Components.API Layer

Core Components.API Layer -> Core Components.Processor
Core Components.Processor -> Core Components.State: "Check if processed"
Core Components.State -> Data Stores.State File: "Read/Write"

Core Components.Processor -> Core Components.Profiles: "Create/Update"
Core Components.Profiles -> Data Stores.Profile Dirs: "Write markdown"

Core Components.Monitor -> Core Components.Processor: "Orchestrates"
Core Components.Monitor -> Data Stores.Log File: "Logs activity"

Data Stores.Profile Dirs -> Integrations.Meeting Prep: "Could reference\n(OPPORTUNITY)" {
  style.stroke-dash: 3
}

Data Stores.Profile Dirs -> Integrations.Transcript Proc: "Could update\n(OPPORTUNITY)" {
  style.stroke-dash: 3
}

Data Stores.Profile Dirs -> Integrations.CRM: "Should sync\n(HIGH PRIORITY)" {
  style.stroke-dash: 3
  style.stroke: "#dc2626"
  style.stroke-width: 2
}

Core Components.Profiles -> Integrations.Lists: "Could add stakeholders\n(OPPORTUNITY)" {
  style.stroke-dash: 3
}

Risk Legend: {
  shape: rectangle
  style.stroke: "#64748b"
  
  Safe: {
    shape: rectangle
    style.stroke: "#059669"
    label: "Safe - No conflicts"
  }
  
  Opportunity: {
    shape: rectangle
    style.stroke: "#f59e0b"
    label: "Integration opportunity"
  }
  
  Risk: {
    shape: rectangle
    style.stroke: "#dc2626"
    label: "Needs attention"
  }
}
