{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n5os-lite.local/schemas/list_entry.schema.json",
  "title": "N5OS Lite JSONL List Entry",
  "description": "Schema for structured list entries (tools, contacts, knowledge)",
  "type": "object",
  "required": ["name", "slug", "created", "updated"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name",
      "minLength": 1,
      "maxLength": 200
    },
    "slug": {
      "type": "string",
      "description": "Machine-readable identifier (lowercase, hyphens)",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "type": {
      "type": "string",
      "description": "Entry category/type",
      "examples": ["tool", "prompt", "script", "person", "company", "concept"]
    },
    "description": {
      "type": "string",
      "description": "Brief description of the entry",
      "maxLength": 500
    },
    "tags": {
      "type": "array",
      "description": "Categorization tags (lowercase)",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "url": {
      "type": "string",
      "description": "External URL reference",
      "format": "uri"
    },
    "location": {
      "type": "string",
      "description": "File path or location within workspace"
    },
    "created": {
      "type": "string",
      "description": "Creation date",
      "format": "date"
    },
    "updated": {
      "type": "string",
      "description": "Last update date",
      "format": "date"
    },
    "status": {
      "type": "string",
      "description": "Entry status",
      "enum": ["active", "archived", "deprecated", "draft"]
    }
  },
  "examples": [
    {
      "name": "Planning Prompt",
      "slug": "planning-prompt",
      "type": "prompt",
      "description": "Think→Plan→Execute framework for system building",
      "tags": ["planning", "architecture", "workflow"],
      "location": "Prompts/planning_prompt.md",
      "created": "2025-11-03",
      "updated": "2025-11-03",
      "status": "active"
    }
  ]
}
