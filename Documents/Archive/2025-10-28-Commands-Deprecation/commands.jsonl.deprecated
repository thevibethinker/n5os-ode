{"trigger": "validate-meeting-folders", "description": "Validate meeting folder naming conventions (detect date/name/ format violations)", "command": "python3 /home/workspace/N5/scripts/validate_meeting_folder_names.py", "category": "validation", "requires_approval": false, "tags": ["meetings", "validation", "structure"]}
{"trigger": "n5-protect", "description": "Protect a directory from accidental moves/deletes", "command": "python3 /home/workspace/N5/scripts/n5_protect.py protect {path} --reason \"{reason}\"", "category": "safety", "requires_approval": false, "tags": ["protection", "safety", "filesystem"]}
{"trigger": "n5-unprotect", "description": "Remove protection from a directory", "command": "python3 /home/workspace/N5/scripts/n5_protect.py unprotect {path}", "category": "safety", "requires_approval": false, "tags": ["protection", "safety", "filesystem"]}
{"trigger": "n5-list-protected", "description": "List all protected directories", "command": "python3 /home/workspace/N5/scripts/n5_protect.py list", "category": "safety", "requires_approval": false, "tags": ["protection", "safety", "filesystem"]}
{"trigger": "n5-check-protected", "description": "Check if a path is protected", "command": "python3 /home/workspace/N5/scripts/n5_protect.py check {path}", "category": "safety", "requires_approval": false, "tags": ["protection", "safety", "filesystem"]}
{"trigger": "slack-send", "description": "Send a message to a Slack channel", "command": "python3 /home/workspace/N5/scripts/slack_send.py {channel} -m \"{message}\"", "category": "communication", "requires_approval": false, "tags": ["slack", "messaging", "communication"]}
{"trigger": "slack-send-file", "description": "Upload a file to a Slack channel", "command": "python3 /home/workspace/N5/scripts/slack_send.py {channel} -f {file_path} -m \"{message}\"", "category": "communication", "requires_approval": false, "tags": ["slack", "file-sharing", "communication"]}
{"trigger": "slack-read", "description": "Read recent messages from a Slack channel", "command": "python3 /home/workspace/N5/scripts/slack_read.py {channel} -l {limit}", "category": "communication", "requires_approval": false, "tags": ["slack", "messaging", "monitoring"]}
{"trigger": "slack-read-recent", "description": "Read messages from last N hours in a Slack channel", "command": "python3 /home/workspace/N5/scripts/slack_read.py {channel} --hours {hours} -l 50", "category": "communication", "requires_approval": false, "tags": ["slack", "messaging", "monitoring"]}
