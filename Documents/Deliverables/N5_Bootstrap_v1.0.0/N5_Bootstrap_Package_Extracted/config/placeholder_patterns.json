{
  "version": "1.0.0",
  "description": "Detection patterns for placeholder and incomplete code (P16, P21 enforcement)",
  "patterns": {
    "comment_placeholders": {
      "enabled": true,
      "patterns": [
        "TODO",
        "FIXME",
        "PLACEHOLDER",
        "XXX",
        "HACK",
        "TEMP",
        "TBD",
        "INCOMPLETE",
        "NOT IMPLEMENTED"
      ],
      "severity": "medium",
      "message": "Undocumented placeholder comment"
    },
    "fake_data": {
      "enabled": true,
      "patterns": [
        "example@example\\.com",
        "test@test\\.com",
        "user@domain\\.com",
        "name@email\\.com",
        "sample@.*\\.com",
        "555-\\d{4}",
        "\\d{3}-\\d{2}-\\d{4}",
        "pk_test_[a-zA-Z0-9]+",
        "sk_test_[a-zA-Z0-9]+",
        "AKIA[A-Z0-9]{16}",
        "dummy[-_]",
        "fake[-_]",
        "test[-_]data",
        "placeholder[-_]",
        "lorem ipsum"
      ],
      "severity": "high",
      "message": "Fake or placeholder data detected"
    },
    "function_stubs": {
      "enabled": true,
      "patterns": [
        "def \\w+\\([^)]*\\):\\s*pass\\s*$",
        "def \\w+\\([^)]*\\):\\s*return \\{\\}\\s*$",
        "def \\w+\\([^)]*\\):\\s*return None\\s*$",
        "def \\w+\\([^)]*\\):\\s*return \\[\\]\\s*$",
        "function \\w+\\([^)]*\\)\\s*\\{\\s*\\}",
        "const \\w+ = \\([^)]*\\) => \\{\\}"
      ],
      "severity": "high",
      "message": "Function stub without implementation or docstring"
    },
    "invented_constraints": {
      "enabled": true,
      "patterns": [
        "(API|limit|max|maximum|restricted).{0,30}\\b(3|5|10)\\b.{0,20}(messages?|calls?|requests?|items?)",
        "can only.{0,30}\\b\\d+\\b",
        "limited to.{0,30}\\b\\d+\\b",
        "restricted to.{0,30}\\b\\d+\\b"
      ],
      "severity": "critical",
      "message": "Potential invented constraint (P16 violation)"
    },
    "hardcoded_paths": {
      "enabled": true,
      "patterns": [
        "/Users/[^/]+/",
        "/home/(?!workspace)[^/]+/",
        "C:\\\\Users\\\\",
        "localhost:\\d{4}(?![^\"']*config)",
        "/tmp/hardcoded"
      ],
      "severity": "medium",
      "message": "Hardcoded path that should be configurable"
    },
    "empty_exception_handlers": {
      "enabled": true,
      "patterns": [
        "except\\s*:\\s*pass",
        "except Exception\\s*:\\s*pass",
        "except \\w+Error\\s*:\\s*pass",
        "catch\\s*\\([^)]*\\)\\s*\\{\\s*\\}"
      ],
      "severity": "high",
      "message": "Empty exception handler (P19 violation)"
    },
    "unclosed_context": {
      "enabled": true,
      "patterns": [
        "open\\([^)]+\\)(?!.*with)",
        "\\.connect\\((?!.*\\.close\\()"
      ],
      "severity": "medium",
      "message": "Potential unclosed resource"
    }
  },
  "file_type_rules": {
    "python": {
      "extensions": [
        ".py"
      ],
      "check_patterns": [
        "comment_placeholders",
        "fake_data",
        "function_stubs",
        "invented_constraints",
        "hardcoded_paths",
        "empty_exception_handlers"
      ]
    },
    "shell": {
      "extensions": [
        ".sh",
        ".bash"
      ],
      "check_patterns": [
        "comment_placeholders",
        "fake_data",
        "hardcoded_paths"
      ]
    },
    "javascript": {
      "extensions": [
        ".js",
        ".ts",
        ".jsx",
        ".tsx"
      ],
      "check_patterns": [
        "comment_placeholders",
        "fake_data",
        "function_stubs",
        "invented_constraints",
        "hardcoded_paths",
        "empty_exception_handlers"
      ]
    },
    "markdown": {
      "extensions": [
        ".md"
      ],
      "check_patterns": [
        "fake_data",
        "invented_constraints"
      ]
    },
    "config": {
      "extensions": [
        ".json",
        ".yaml",
        ".yml",
        ".toml",
        ".ini"
      ],
      "check_patterns": [
        "fake_data",
        "hardcoded_paths"
      ]
    }
  },
  "exclusions": {
    "patterns": [
      "# KNOWN:",
      "# DOCUMENTED:",
      "# INTENTIONAL:"
    ],
    "description": "Lines containing these prefixes are excluded from placeholder detection"
  }
}