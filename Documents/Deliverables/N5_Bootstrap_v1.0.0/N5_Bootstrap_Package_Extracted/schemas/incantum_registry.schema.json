{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n5.local/schemas/incantum_registry.schema.json",
  "title": "N5 Incantum Trigger Registry Schema",
  "description": "Schema for validating incantum trigger definitions and their mapping to N5 commands",
  "type": "object",
  "properties": {
    "triggers": {
      "type": "array",
      "description": "Array of incantum trigger definitions",
      "items": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "description": "N5 command name that this trigger executes",
            "pattern": "^[a-z-]+[a-z0-9-]*$"
          },
          "primary_trigger": {
            "type": "string",
            "description": "Primary natural language trigger phrase",
            "minLength": 3,
            "maxLength": 100
          },
          "aliases": {
            "type": "array",
            "description": "Alternative trigger phrases",
            "items": {
              "type": "string",
              "minLength": 3,
              "maxLength": 100
            },
            "maxItems": 5
          },
          "destructive": {
            "type": "boolean",
            "description": "Whether this command is destructive (requires confirmation)",
            "default": false
          },
          "confidence_threshold": {
            "type": "number",
            "description": "Minimum confidence score required (0.0-1.0)",
            "minimum": 0.0,
            "maximum": 1.0,
            "default": 0.8
          },
          "category": {
            "type": "string",
            "description": "Trigger category for organization",
            "enum": ["lists", "ops", "knowledge", "automation", "system"]
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of what the trigger does",
            "maxLength": 200
          }
        },
        "required": ["command", "primary_trigger", "category", "description"]
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "description": "Registry version",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "last_updated": {
          "type": "string",
          "description": "ISO timestamp of last update",
          "format": "date-time"
        },
        "total_triggers": {
          "type": "integer",
          "description": "Total number of registered triggers",
          "minimum": 0
        }
      },
      "required": ["version", "last_updated", "total_triggers"]
    }
  },
  "required": ["triggers", "metadata"],
  "additionalProperties": false
}