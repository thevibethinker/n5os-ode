{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://va.zo.computer/schemas/aar.schema.json",
  "title": "After-Action Report (AAR) Schema",
  "description": "Schema for conversation thread After-Action Reports (AAR v2.0)",
  "type": "object",
  "required": [
    "thread_id",
    "archived_date",
    "title",
    "executive_summary",
    "key_events",
    "final_state",
    "primary_objective",
    "next_steps",
    "aar_version"
  ],
  "properties": {
    "thread_id": {
      "type": "string",
      "pattern": "^con_[A-Za-z0-9]{16}$",
      "description": "Conversation thread identifier"
    },
    "archived_date": {
      "type": "string",
      "format": "date",
      "description": "Date AAR was created (YYYY-MM-DD)"
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Descriptive title for the thread (used in archive directory name)"
    },
    "executive_summary": {
      "type": "object",
      "required": ["purpose", "outcome"],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 20,
          "description": "2-3 sentences: what was the conversation about?"
        },
        "outcome": {
          "type": "string",
          "minLength": 20,
          "description": "1-2 sentences: what was accomplished?"
        },
        "context": {
          "type": "string",
          "description": "Optional: additional context for future reference"
        }
      }
    },
    "key_events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "description": "Chronological list of key decisions and events",
      "items": {
        "type": "object",
        "required": ["description", "rationale"],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "time",
            "description": "Approximate time (HH:MM) if known"
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "description": "What happened"
          },
          "rationale": {
            "type": "string",
            "description": "Why it matters / why this decision was made"
          },
          "type": {
            "type": "string",
            "enum": ["decision", "discovery", "pivot", "challenge", "milestone"],
            "description": "Event classification"
          }
        }
      }
    },
    "final_state": {
      "type": "object",
      "required": ["summary", "artifacts"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 20,
          "description": "Brief summary of ending state"
        },
        "artifacts": {
          "type": "array",
          "description": "Files created or modified during conversation",
          "items": {
            "type": "object",
            "required": ["filename", "description"],
            "properties": {
              "filename": {
                "type": "string",
                "description": "Relative path from archive directory"
              },
              "description": {
                "type": "string",
                "minLength": 10,
                "description": "Purpose and content of the file"
              },
              "type": {
                "type": "string",
                "enum": ["script", "document", "data", "config", "image", "other"],
                "description": "File category"
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 0,
                "description": "File size in bytes"
              },
              "created_at": {
                "type": "string",
                "format": "date-time",
                "description": "When file was created (ISO 8601)"
              },
              "modified_at": {
                "type": "string",
                "format": "date-time",
                "description": "When file was last modified (ISO 8601)"
              }
            }
          }
        }
      }
    },
    "primary_objective": {
      "type": "string",
      "minLength": 20,
      "description": "Single clear sentence: what should happen next?"
    },
    "next_steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "description": "Actionable steps for continuation",
      "items": {
        "type": "object",
        "required": ["action", "details"],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 5,
            "description": "Concise action statement"
          },
          "details": {
            "type": "string",
            "description": "Additional context or dependencies"
          },
          "priority": {
            "type": "string",
            "enum": ["H", "M", "L"],
            "description": "Priority level"
          },
          "estimated_duration": {
            "type": "string",
            "description": "e.g., '2 hours', '1 day', '1 week'"
          }
        }
      }
    },
    "aar_version": {
      "type": "string",
      "const": "2.0",
      "description": "AAR protocol version"
    },
    "tags": {
      "type": "array",
      "description": "Optional: categorization tags",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "related_threads": {
      "type": "array",
      "description": "Optional: related conversation thread IDs",
      "items": {
        "type": "string",
        "pattern": "^con_[A-Za-z0-9]{16}$"
      }
    },
    "system_upgrades_referenced": {
      "type": "array",
      "description": "Optional: system upgrade items affected",
      "items": {
        "type": "string"
      }
    },
    "commands_used": {
      "type": "array",
      "description": "Optional: N5 commands executed during conversation",
      "items": {
        "type": "string"
      }
    },
    "telemetry": {
      "type": "object",
      "description": "Optional: metrics and metadata",
      "properties": {
        "conversation_duration_minutes": {
          "type": "integer",
          "minimum": 0
        },
        "artifacts_created": {
          "type": "integer",
          "minimum": 0
        },
        "artifacts_modified": {
          "type": "integer",
          "minimum": 0
        },
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "aar_generated_by": {
          "type": "string",
          "description": "Who/what generated this AAR"
        },
        "aar_generation_method": {
          "type": "string",
          "enum": ["interactive", "progressive", "automated", "manual", "smart_extraction"],
          "description": "How AAR was generated"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional: additional metadata",
      "properties": {
        "conversation_type": {
          "type": "string",
          "enum": ["coding", "research", "planning", "debugging", "meeting-processing", "system-design", "other"]
        },
        "participants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
