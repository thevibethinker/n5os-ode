{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "content-library-v3.schema.json",
  "title": "Content Library v3 Schema",
  "description": "JSON Schema for validating Content Library v3 items",
  "type": "object",
  "definitions": {
    "item": {
      "type": "object",
      "required": ["id", "item_type", "title"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (slug format)"
        },
        "item_type": {
          "type": "string",
          "enum": ["link", "snippet", "article", "deck", "social-post", "podcast", "video", "book", "paper", "framework", "quote", "resource", "meeting", "newsletter", "case-study"],
          "description": "Content type"
        },
        "title": {
          "type": "string",
          "description": "Item title"
        },
        "url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "External URL (for links, articles, etc.)"
        },
        "content": {
          "type": ["string", "null"],
          "description": "Inline content (for snippets, quotes)"
        },
        "content_path": {
          "type": ["string", "null"],
          "description": "Path to stored full-text file (for assets)"
        },
        "summary": {
          "type": ["string", "null"],
          "description": "Brief summary"
        },
        "summary_path": {
          "type": ["string", "null"],
          "description": "Path to stored summary file"
        },
        "word_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "source_type": {
          "type": "string",
          "enum": ["created", "discovered", "manual", "migration"],
          "default": "manual",
          "description": "How this item was added"
        },
        "platform": {
          "type": ["string", "null"],
          "description": "Source platform (gamma.app, twitter, medium, etc.)"
        },
        "author": {
          "type": ["string", "null"],
          "description": "Original author (for discovered content)"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "deprecated": {
          "type": "integer",
          "enum": [0, 1],
          "default": 0
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "last_used_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "confidence": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 5,
          "default": 3
        },
        "has_content": {
          "type": "integer",
          "enum": [0, 1],
          "default": 0
        },
        "has_summary": {
          "type": "integer",
          "enum": [0, 1],
          "default": 0
        },
        "notes": {
          "type": ["string", "null"]
        },
        "source": {
          "type": ["string", "null"],
          "description": "Migration source: n5_links, personal_cl, new"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tag_key", "tag_value"],
            "properties": {
              "tag_key": { "type": "string" },
              "tag_value": { "type": "string" }
            }
          }
        },
        "topics": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["id", "item_id", "content"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Block unique identifier"
        },
        "item_id": {
          "type": "string",
          "description": "Parent item ID"
        },
        "block_code": {
          "type": ["string", "null"],
          "description": "Block code (B01, B02, etc.)"
        },
        "block_type": {
          "type": ["string", "null"],
          "enum": ["quote", "insight", "action", "resource", null],
          "description": "Type of block content"
        },
        "content": {
          "type": "string",
          "description": "Block content text"
        },
        "context": {
          "type": ["string", "null"],
          "description": "Surrounding context"
        },
        "speaker": {
          "type": ["string", "null"],
          "description": "Speaker name if from transcript"
        },
        "file_path": {
          "type": ["string", "null"],
          "description": "Path to block file"
        },
        "line_start": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "line_end": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "extracted_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "confidence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 3
        },
        "topics": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "topic": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "relationship": {
      "type": "object",
      "required": ["from_id", "to_id", "rel_type"],
      "properties": {
        "from_id": { "type": "string" },
        "to_id": { "type": "string" },
        "rel_type": {
          "type": "string",
          "enum": ["related_to", "references", "derived_from"]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "properties": {
    "items": {
      "type": "array",
      "items": { "$ref": "#/definitions/item" }
    },
    "blocks": {
      "type": "array",
      "items": { "$ref": "#/definitions/block" }
    },
    "topics": {
      "type": "array",
      "items": { "$ref": "#/definitions/topic" }
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/definitions/relationship" }
    },
    "schema_version": {
      "type": "integer",
      "const": 3
    }
  }
}

