# =============================================================================
# N5OS Workspace .gitignore
# Policy: Track source, config, docs, schemas, templates.
#         Ignore runtime state, caches, logs, build outputs, databases.
# Updated: 2026-03-14
# =============================================================================

# === GLOBAL PATTERNS ===

# Temp, swap, backup files
*.log
*.tmp
*.bak
*.swp
*.backup
*.backup_*

# Auto-versioned files (P05 anti-overwrite artifacts)
*_[0-9].json
*_[0-9].jsonl
*_[0-9].md
*_[0-9].py
*_[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]_[0-9][0-9][0-9][0-9][0-9][0-9]*

# Large media files
*.wav
*.mp3
*.m4a
*.mp4
*.avi
*.mov
*.flv

# Databases — NEVER in git (binary, unmergeable)
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.db-journal
*.duckdb
*.duckdb.wal

# Exception: schema and migration SQL files ARE tracked
!**/schema.sql
!**/migrations/*.sql
!**/seeds/*.sql

# Dependencies and caches
node_modules/
__pycache__/
.venv/
.cache/
.pytest_cache/

# Secrets (P23)
.env
.env.*

# === BACKUP / ARCHIVE DIRECTORIES ===
BackupArchive/
Backups/
Misc/
_local_archives/

# === N5 RUNTIME STATE (never track) ===

# Runtime infrastructure
N5/runtime/
N5/cache/
N5/tmp/
N5/backups/
N5/archives/
N5/exports/

# Generated indexes and docs (regenerated by docgen/indexer)
N5/commands.md
N5/index.md
N5/index.jsonl
N5/lists/*.md

# Logs — operational exhaust
N5/logs/

# Inbox — transient processing queue
N5/inbox/

# Digests and reports — generated outputs
N5/digests/
N5/reports/daily/

# Review queues — generated HITL artifacts
N5/review/

# Data — runtime state files
N5/data/

# Exception: keep data schemas, documentation, and .n5protected markers
!N5/data/.n5protected
!N5/data/.gitkeep
!N5/data/ASSUMPTIONS.md

# Cognition — vector stores, entity caches, model artifacts
N5/cognition/entity_cache/
N5/cognition/brain.hnsw
N5/cognition/brain.hnsw.ids
N5/cognition/models/
N5/cognition/vectors_v2.db.bak.*
N5/cognition/pageindex/lib/

# Exception: cognition source code IS tracked
!N5/cognition/*.py
!N5/cognition/*.sh
!N5/cognition/schema.sql

# Builds — PLAN.md, meta.json, drops/, deposits/, artifacts/ ARE tracked
# (build artifacts are intellectual output, not runtime noise)

# Audit logs
N5/audit/

# Secrets
N5/config/secrets.jsonl
N5/config/.secrets.key
N5/config/credentials/
N5/config/credentials_backup_20251028/
N5/config/tally_api_key.env
N5/config/slack_credentials.json
N5/services/n8n_processor/.env

# === SKILLS RUNTIME STATE ===

# All skill state directories — runtime data, not source
Skills/*/state/
Skills/.backups/

# Exception: SKILL.md, scripts/, references/, assets/ ARE tracked (default)

# === SITES — INDEPENDENT REPOS ===
# Each site has its own .git; root repo ignores them entirely

Sites/vrijenattawar/
Sites/vrijenattawar-staging/
Sites/keanu-to-market/
Sites/keanu-to-market-staging/
Sites/store-va/
Sites/store-va-staging/
Sites/plaid-pfm/
Sites/string-staging/
Sites/thevibepill/
Sites/thevibepill-staging/

# === BUILD EXPORTS — INDEPENDENT REPOS ===
Build Exports/

# === PROJECTS — INDEPENDENT REPOS ===
Projects/

# === OTHER EMBEDDED REPOS ===
zoputer-substrate/

# === TOP-LEVEL MISFILED / TRANSIENT DIRS ===
AgentCommune/
Logs/
Trash/

# === ROOT-LEVEL JUNK (one-off scripts, temp outputs, stray files) ===
# These accumulate from ad-hoc work sessions; ignore them all
/*.pdf
/*.pptx
/*.docx
/*.zip
/*.jpg
/*.html
/*.csv
/*.pid
/find_emails*.py
/blurb_batch.py
/generate_blocks.py
/gmail_search.py
/mg1_process.py
/mg2_processor.py
/run_stakeholder_sync.py
/stakeholder_runner.py
/enrichment_output.md
/drive_files_list.txt
/gdrive_*.txt
/flight_results.json
/events.json
/final_events*.json
/missing_emails.json
/B[0-9][0-9]_*.md
/B[0-9][0-9]_*.jsonl
/MG*_EXECUTION_REPORT.md
/WORKER_*_COMPLETE.md
/DESIGN_SYSTEM.md
/HEARTBEAT.md
/IDENTITY.md
/PERSONALIZE.prompt.md
/TOOLS.md
/USER.md
/PLAN.md
/ZOFFICE_WORKERS

# === ROOT-LEVEL STRAY FILES ===
/.mg1_execution_report.md
/.n5_productivity_protected
/.n5protected
/.productivity_db_protected
/.schema
/1672d1c37bfe801d8fc0cd76eb5f508f
/install.sh
/package.json
/_TASKS.md
/"_ 📌 TASKS.md"

# === RUNTIME PID / CHECKPOINT FILES ===
N5/cognition/migration.pid
N5/cognition/migration_checkpoint.json

# === PERSONAL RUNTIME LOGS ===
Personal/agentcommune/
Personal/agentcommune_logs/

# === SKILL RUNTIME LOGS/ANALYSIS ===
Skills/*/logs/
Skills/*/analysis/
Skills/zoren-hotline/

# === TEMP WORKTREES ===
Temp/

# === SYSTEM / INTERNAL ===
.config/syncthing/
.zo/conversations/zo_conversations.duckdb
.zo/conversations/zo_conversations.duckdb.wal
.zo/conversations/_staging/duckdb_payload_*.json

# Legacy local project paths
projects/n5-system/n5-core/
projects/n5-system/n5-launch/

# === DATASET ARCHIVES (large files) ===
Datasets/x-history-pre-jan-8/*.zip
Datasets/*/data.duckdb
Datasets/*/data.duckdb.wal
/*TASKS.md
