# N5 OS .gitignore: Targeted for stable preferences and core docs
# Ignore temp, logs, and auto-generated files
*.log
*.tmp
*.bak
*.swp
*.backup
*.backup_*
*_[0-9].json
*_[0-9].jsonl
*_[0-9].md
*_[0-9].py
*_[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]_[0-9][0-9][0-9][0-9][0-9][0-9]*

# Ignore backup and temporary directories
BackupArchive/
Backups/
Misc/
N5/backups/
N5/archives/

# Ignore runtime logs and transient data
N5/runtime/
N5/cache/
N5/tmp/

# Ignore generated outputs and views (regenerated by docgen/indexer)
N5/commands.md
N5/lists/*.md
N5/index.md
N5/index.jsonl
N5/exports/

# Ignore dependency dirs if present
node_modules/
__pycache__/

# Track only stable, manually managed files
!N5/
# Exclude runtime and generated from tracking
N5/runtime/
N5/cache/
N5/tmp/
N5/exports/
# Exclude generated docs
N5/commands.md
N5/index.md
N5/index.jsonl
N5/lists/*.md

# Explicitly track core stable files
!N5/prefs.md
!N5/knowledge/
!N5/modules/
!N5/flows/
!N5/schemas/
!N5/scripts/
!N5/examples/
!N5/lists/*.jsonl
!N5/commands.jsonlsourcestack/credentials.md

# Whitelist core command doc required by audit
!N5/commands/direct-knowledge-ingest.md

# Large media files (meeting recordings, audio)
*.wav
*.mp3
*.m4a
*.mp4
*.avi
*.mov
*.flv

# Local project repos (ignored)
projects/n5-system/n5-core/
projects/n5-system/n5-launch/
N5/config/tally_api_key.env

# Secrets Management (P23)
N5/config/secrets.jsonl
N5/config/.secrets.key
N5/config/credentials/
N5/services/n8n_processor/.env
N5/services/*/config files
N5/data/secrets_audit.jsonl
N5/config/slack_credentials.json

# === DATABASES - NEVER IN GIT (Added 2025-11-03) ===
# Operational databases are runtime data, not source code
# Git cannot safely merge binary SQLite files
# Use automated snapshots for backups instead
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# System config with runtime state
.config/syncthing/

# Exception: Allow schema and migration files
!**/schema.sql
!**/migrations/*.sql
!**/seeds/*.sql
_local_archives/

# Secrets
.env
.env.*


# Large Cognition Artifacts
N5/cognition/brain.hnsw
N5/cognition/brain.hnsw.ids
N5/cognition/models/
.cache/
.zo/conversations/zo_conversations.duckdb
.zo/conversations/zo_conversations.duckdb.wal

# DuckDB staging payloads (auto-generated, ephemeral)
.zo/conversations/_staging/duckdb_payload_*.json
Build Exports/
Sites/keanu-to-market-staging/
N5/cognition/vectors_v2.db.bak.*
