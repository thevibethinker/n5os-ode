{
  "description": "Sample validation rubrics for different block types",
  "version": "1.0",
  "created": "2025-11-03",
  
  "external_meeting_blocks": {
    "B01_DETAILED_RECAP": {
      "required_sections": ["## Meeting Context", "## Key Discussion Points", "## Outcomes"],
      "min_length": 200,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_bullet_points": true
      }
    },
    
    "B02_COMMITMENTS": {
      "required_sections": ["## Commitments Made", "## Timeline"],
      "min_length": 100,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_bullet_points": true
      }
    },
    
    "B08_STAKEHOLDER_INTELLIGENCE": {
      "required_sections": ["## Key Stakeholders", "## Organizational Context"],
      "min_length": 150,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_bullet_points": true
      }
    },
    
    "B13_PLAN_OF_ACTION": {
      "required_sections": ["## Immediate Actions", "## Next Steps"],
      "min_length": 100,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_bullet_points": true,
        "require_numbered_list": false
      }
    },
    
    "B21_KEY_MOMENTS": {
      "required_sections": ["## Highlights"],
      "min_length": 80,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_bullet_points": true
      }
    }
  },
  
  "internal_meeting_blocks": {
    "B40_INTERNAL_DECISIONS": {
      "required_sections": ["## Strategic Decisions", "## Tactical Decisions"],
      "min_length": 100,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_bullet_points": true
      }
    },
    
    "B41_TEAM_COORDINATION": {
      "required_sections": ["## Action Items"],
      "min_length": 80,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_bullet_points": true
      },
      "forbidden_patterns": ["TBD", "TODO", "Unassigned"]
    },
    
    "B47_OPEN_DEBATES": {
      "required_sections": ["## Unresolved Questions"],
      "min_length": 50,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_bullet_points": true
      }
    }
  },
  
  "reflection_blocks": {
    "B50_PERSONAL_REFLECTION": {
      "min_length": 200,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_paragraphs": true
      }
    },
    
    "B60_LEARNING_SYNTHESIS": {
      "required_sections": ["## Key Insights", "## Applications"],
      "min_length": 250,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_paragraphs": true
      }
    },
    
    "B70_THOUGHT_LEADERSHIP": {
      "min_length": 400,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_paragraphs": true
      }
    },
    
    "B80_LINKEDIN_POST": {
      "min_length": 100,
      "structure_rules": {
        "must_start_with_heading": false,
        "require_paragraphs": true
      }
    },
    
    "B81_BLOG_POST": {
      "required_sections": ["## Introduction", "## Conclusion"],
      "min_length": 800,
      "structure_rules": {
        "must_start_with_heading": true,
        "require_paragraphs": true
      }
    }
  },
  
  "default_rubric": {
    "description": "Used when block has no specific rubric",
    "required_sections": [],
    "min_length": 100,
    "structure_rules": {
      "must_start_with_heading": true,
      "no_excessive_whitespace": true
    }
  },
  
  "strict_rubric": {
    "description": "High-quality content requirements",
    "required_sections": [],
    "min_length": 200,
    "structure_rules": {
      "must_start_with_heading": true,
      "require_bullet_points": true,
      "require_paragraphs": true,
      "no_excessive_whitespace": true
    },
    "forbidden_patterns": ["TBD", "TODO", "[Insert", "[Add", "..."]
  },
  
  "lenient_rubric": {
    "description": "Minimal requirements for drafts",
    "min_length": 50,
    "structure_rules": {
      "no_excessive_whitespace": true
    }
  }
}
