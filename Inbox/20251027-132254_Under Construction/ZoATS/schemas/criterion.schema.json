{
  "": "https://json-schema.org/draft/2020-12/schema",
  "": "https://va.local/zoats/schemas/criterion.schema.json",
  "title": "Criterion",
  "type": "object",
  "required": ["id","name","dimension","description","evidence_types","levels"],
  "properties": {
    "id": {"type": "string"},
    "name": {"type": "string"},
    "dimension": {"type": "string", "enum": ["Craft","Speed","Ownership","Collaboration","Communication","Judgment","Resilience","Product Sense","Technical Depth","Design Taste"]},
    "description": {"type": "string"},
    "evidence_types": {"type": "array", "items": {"type": "string", "enum": ["Portfolio","PR","Code","DesignArtifact","Demo","Reference","Scenario","TrialTask","InterviewNote"]}},
    "levels": {"type": "array", "minItems": 4, "items": {"type": "object", "required":["level","label","behavioral_indicators"], "properties": {"level":{"type":"integer","minimum":1,"maximum":4},"label":{"type":"string"},"behavioral_indicators":{"type":"array","items":{"type":"string"}}}}},
    "weight_default": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
