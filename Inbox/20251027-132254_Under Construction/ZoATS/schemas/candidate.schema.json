{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zoats.careerspan.com/schemas/candidate.schema.json",
  "title": "ZoATS Candidate Evaluation Record",
  "description": "Complete evaluation record for a single candidate",
  "type": "object",
  "required": [
    "candidate_id",
    "job_id",
    "application_date",
    "status",
    "contact_info"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "description": "Unique candidate identifier",
      "pattern": "^[a-z0-9-]+$"
    },
    "job_id": {
      "type": "string",
      "description": "Job this application is for"
    },
    "application_date": {
      "type": "string",
      "format": "date-time"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "new",
        "quick_test_pass",
        "quick_test_fail",
        "screening_sent",
        "screening_response_pending",
        "deep_evaluation_in_progress",
        "review_needed",
        "rejected",
        "interview_recommended",
        "finalist",
        "hired",
        "withdrawn"
      ]
    },
    "contact_info": {
      "type": "object",
      "required": ["email"],
      "properties": {
        "name": {"type": "string"},
        "email": {"type": "string", "format": "email"},
        "phone": {"type": "string"},
        "location": {"type": "string"},
        "linkedin": {"type": "string", "format": "uri"},
        "github": {"type": "string", "format": "uri"},
        "portfolio": {"type": "string", "format": "uri"},
        "website": {"type": "string", "format": "uri"}
      }
    },
    "application_materials": {
      "type": "object",
      "properties": {
        "resume_path": {"type": "string"},
        "cover_letter_path": {"type": "string"},
        "portfolio_links": {
          "type": "array",
          "items": {"type": "string", "format": "uri"}
        },
        "additional_materials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {"type": "string"},
              "path": {"type": "string"},
              "description": {"type": "string"}
            }
          }
        }
      }
    },
    "parsed_data": {
      "type": "object",
      "description": "Structured data extracted from resume",
      "properties": {
        "work_history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "company": {"type": "string"},
              "title": {"type": "string"},
              "start_date": {"type": "string"},
              "end_date": {"type": "string"},
              "duration_months": {"type": "integer"},
              "description": {"type": "string"},
              "achievements": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "institution": {"type": "string"},
              "degree": {"type": "string"},
              "field": {"type": "string"},
              "graduation_date": {"type": "string"},
              "gpa": {"type": "number"},
              "honors": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "skills": {
          "type": "object",
          "properties": {
            "technical": {"type": "array", "items": {"type": "string"}},
            "soft": {"type": "array", "items": {"type": "string"}},
            "languages": {"type": "array", "items": {"type": "string"}},
            "tools": {"type": "array", "items": {"type": "string"}}
          }
        },
        "certifications": {
          "type": "array",
          "items": {"type": "string"}
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "description": {"type": "string"},
              "url": {"type": "string", "format": "uri"},
              "technologies": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "quick_test_results": {
      "type": "object",
      "description": "First-pass filter results",
      "properties": {
        "timestamp": {"type": "string", "format": "date-time"},
        "passed": {"type": "boolean"},
        "dealbreaker_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "criterion_id": {"type": "string"},
              "passed": {"type": "boolean"},
              "reason": {"type": "string"}
            }
          }
        },
        "initial_flags": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "screening_interaction": {
      "type": "object",
      "description": "Email-based screening questionnaire",
      "properties": {
        "questions_sent_at": {"type": "string", "format": "date-time"},
        "response_received_at": {"type": "string", "format": "date-time"},
        "response_time_hours": {"type": "number"},
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question_id": {"type": "string"},
              "question_text": {"type": "string"},
              "response": {"type": "string"},
              "word_count": {"type": "integer"},
              "ai_likelihood": {"type": "number", "minimum": 0, "maximum": 1},
              "specificity_score": {"type": "number", "minimum": 0, "maximum": 10},
              "uniqueness_score": {"type": "number", "minimum": 0, "maximum": 10}
            }
          }
        }
      }
    },
    "authenticity_analysis": {
      "type": "object",
      "description": "AI-generation and authenticity scoring",
      "properties": {
        "overall_ai_likelihood": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "0 = definitely human, 1 = definitely AI"
        },
        "resume_ai_likelihood": {"type": "number", "minimum": 0, "maximum": 1},
        "cover_letter_ai_likelihood": {"type": "number", "minimum": 0, "maximum": 1},
        "screening_responses_ai_likelihood": {"type": "number", "minimum": 0, "maximum": 1},
        "patterns_detected": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Specific AI patterns found"
        },
        "uniqueness_analysis": {
          "type": "object",
          "properties": {
            "overall_score": {"type": "number", "minimum": 0, "maximum": 10},
            "why_company_specificity": {"type": "number", "minimum": 0, "maximum": 10},
            "compared_to_applicants": {"type": "integer"},
            "unique_elements": {"type": "array", "items": {"type": "string"}},
            "generic_elements": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    },
    "cross_reference_results": {
      "type": "object",
      "description": "External validation of claims",
      "properties": {
        "linkedin_validation": {
          "type": "object",
          "properties": {
            "profile_found": {"type": "boolean"},
            "profile_url": {"type": "string"},
            "work_history_match": {"type": "number", "minimum": 0, "maximum": 1},
            "education_match": {"type": "number", "minimum": 0, "maximum": 1},
            "discrepancies": {"type": "array", "items": {"type": "string"}},
            "endorsements": {"type": "array", "items": {"type": "string"}},
            "recommendations_count": {"type": "integer"}
          }
        },
        "news_mentions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": {"type": "string"},
              "url": {"type": "string", "format": "uri"},
              "title": {"type": "string"},
              "date": {"type": "string"},
              "relevance": {"type": "number", "minimum": 0, "maximum": 1}
            }
          }
        },
        "github_analysis": {
          "type": "object",
          "properties": {
            "username": {"type": "string"},
            "public_repos": {"type": "integer"},
            "contributions_last_year": {"type": "integer"},
            "notable_projects": {"type": "array", "items": {"type": "string"}},
            "primary_languages": {"type": "array", "items": {"type": "string"}},
            "activity_level": {"enum": ["low", "moderate", "high", "very_high"]}
          }
        },
        "portfolio_validation": {
          "type": "object",
          "properties": {
            "portfolio_found": {"type": "boolean"},
            "quality_assessment": {"enum": ["poor", "basic", "good", "excellent", "exceptional"]},
            "work_samples_count": {"type": "integer"},
            "authenticity_signals": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    },
    "rubric_scores": {
      "type": "object",
      "description": "Scores against job rubric",
      "properties": {
        "criteria_groups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "group_id": {"type": "string"},
              "group_score": {"type": "number"},
              "weighted_score": {"type": "number"},
              "criteria_scores": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "criterion_id": {"type": "string"},
                    "raw_score": {"type": "number"},
                    "weighted_score": {"type": "number"},
                    "evidence": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "source": {"type": "string"},
                          "excerpt": {"type": "string"},
                          "strength": {"enum": ["weak", "moderate", "strong"]}
                        }
                      }
                    },
                    "rationale": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "total_score": {"type": "number"},
        "percentile": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "multi_perspective_scores": {
      "type": "object",
      "description": "Simulated panel interview results",
      "properties": {
        "personas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "persona_id": {"type": "string"},
              "persona_role": {"type": "string"},
              "score": {"type": "number"},
              "key_observations": {"type": "array", "items": {"type": "string"}},
              "concerns": {"type": "array", "items": {"type": "string"}},
              "strengths": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "consensus_score": {"type": "number"},
        "disagreement_level": {
          "enum": ["unanimous", "strong_agreement", "moderate_agreement", "divergent"],
          "description": "How much personas disagreed"
        }
      }
    },
    "ultra_signals": {
      "type": "object",
      "description": "Exceptional indicators found",
      "properties": {
        "green_flags_detected": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "signal": {"type": "string"},
              "evidence": {"type": "string"},
              "significance": {"enum": ["minor", "moderate", "major", "exceptional"]}
            }
          }
        },
        "red_flags_detected": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "signal": {"type": "string"},
              "evidence": {"type": "string"},
              "severity": {"enum": ["minor", "moderate", "major", "critical"]}
            }
          }
        }
      }
    },
    "interview_recommendations": {
      "type": "object",
      "properties": {
        "should_interview": {"type": "boolean"},
        "priority_level": {"enum": ["low", "medium", "high", "urgent"]},
        "suggested_questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": {"type": "string"},
              "purpose": {"type": "string"},
              "area_to_probe": {"type": "string"}
            }
          }
        },
        "areas_to_explore": {"type": "array", "items": {"type": "string"}},
        "concerns_to_probe": {"type": "array", "items": {"type": "string"}},
        "strengths_to_validate": {"type": "array", "items": {"type": "string"}}
      }
    },
    "timeline": {
      "type": "array",
      "description": "Complete interaction history",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {"type": "string", "format": "date-time"},
          "event": {"type": "string"},
          "details": {"type": "string"},
          "actor": {"enum": ["system", "candidate", "founder", "ai"]}
        }
      }
    },
    "notes": {
      "type": "array",
      "description": "Manual notes from founder/team",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {"type": "string", "format": "date-time"},
          "author": {"type": "string"},
          "note": {"type": "string"},
          "tags": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
