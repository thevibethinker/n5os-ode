{
  "": "https://json-schema.org/draft/2020-12/schema",
  "": "https://va.local/zoats/schemas/evidence_item.schema.json",
  "title": "EvidenceItem",
  "type": "object",
  "required": ["id","type","source","summary","link"],
  "properties": {
    "id": {"type":"string"},
    "type": {"type":"string", "enum": ["Portfolio","PR","Code","DesignArtifact","Demo","Reference","Scenario","TrialTask","InterviewNote"]},
    "source": {"type":"string"},
    "link": {"type":"string"},
    "summary": {"type":"string"},
    "veracity": {"type":"string", "enum":["self-claim","observable","third-party"]},
    "strength": {"type":"integer","minimum":1,"maximum":5}
  }
}
