{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zoats.careerspan.com/schemas/scoring_config.schema.json",
  "title": "ZoATS Scoring Configuration",
  "description": "System-wide scoring configuration and weights",
  "type": "object",
  "required": ["version", "default_weights", "scoring_methods"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "default_weights": {
      "type": "object",
      "description": "Default weight distributions for common rubric components",
      "properties": {
        "technical_skills": {"type": "number", "minimum": 0, "maximum": 1},
        "soft_skills": {"type": "number", "minimum": 0, "maximum": 1},
        "experience": {"type": "number", "minimum": 0, "maximum": 1},
        "culture_fit": {"type": "number", "minimum": 0, "maximum": 1},
        "motivation": {"type": "number", "minimum": 0, "maximum": 1},
        "learning_ability": {"type": "number", "minimum": 0, "maximum": 1},
        "authenticity": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "role_presets": {
      "type": "object",
      "description": "Pre-configured weight distributions by role type",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "description": {"type": "string"},
            "weights": {
              "type": "object",
              "additionalProperties": {"type": "number"}
            }
          }
        }
      }
    },
    "scoring_methods": {
      "type": "object",
      "description": "Definitions of available scoring methods",
      "properties": {
        "binary": {
          "type": "object",
          "properties": {
            "description": {"type": "string"},
            "scale": {"type": "object", "properties": {"pass": {"type": "number"}, "fail": {"type": "number"}}}
          }
        },
        "scale_1_5": {
          "type": "object",
          "properties": {
            "description": {"type": "string"},
            "scale": {
              "type": "object",
              "properties": {
                "1": {"type": "string"},
                "2": {"type": "string"},
                "3": {"type": "string"},
                "4": {"type": "string"},
                "5": {"type": "string"}
              }
            }
          }
        },
        "scale_1_10": {
          "type": "object",
          "properties": {
            "description": {"type": "string"},
            "interpretation": {
              "type": "object",
              "properties": {
                "poor": {"type": "string"},
                "below_average": {"type": "string"},
                "average": {"type": "string"},
                "above_average": {"type": "string"},
                "excellent": {"type": "string"}
              }
            }
          }
        },
        "percentile": {
          "type": "object",
          "properties": {
            "description": {"type": "string"},
            "requires_cohort": {"type": "boolean"}
          }
        },
        "comparative": {
          "type": "object",
          "properties": {
            "description": {"type": "string"},
            "min_candidates": {"type": "integer"}
          }
        },
        "evidence_count": {
          "type": "object",
          "properties": {
            "description": {"type": "string"},
            "thresholds": {
              "type": "object",
              "properties": {
                "poor": {"type": "integer"},
                "adequate": {"type": "integer"},
                "strong": {"type": "integer"},
                "exceptional": {"type": "integer"}
              }
            }
          }
        }
      }
    },
    "normalization_config": {
      "type": "object",
      "description": "How to normalize scores across candidates",
      "properties": {
        "enabled": {"type": "boolean", "default": true},
        "method": {"enum": ["z_score", "min_max", "percentile"]},
        "apply_after_candidates": {
          "type": "integer",
          "default": 5,
          "description": "Start normalizing after N candidates"
        }
      }
    },
    "threshold_defaults": {
      "type": "object",
      "description": "Default score thresholds (0-100 scale)",
      "properties": {
        "reject": {"type": "number", "default": 40},
        "review": {"type": "number", "default": 60},
        "interview": {"type": "number", "default": 75},
        "finalist": {"type": "number", "default": 85}
      }
    },
    "authenticity_scoring": {
      "type": "object",
      "description": "Configuration for authenticity analysis",
      "properties": {
        "ai_detection_models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "weight": {"type": "number"},
              "threshold": {"type": "number"}
            }
          }
        },
        "uniqueness_analysis": {
          "type": "object",
          "properties": {
            "compare_against": {
              "enum": ["all_candidates", "job_candidates", "similar_roles"]
            },
            "min_candidates_for_comparison": {"type": "integer", "default": 3},
            "semantic_similarity_threshold": {"type": "number", "default": 0.8}
          }
        },
        "specificity_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metric": {"type": "string"},
              "weight": {"type": "number"}
            }
          }
        }
      }
    },
    "multi_perspective_config": {
      "type": "object",
      "description": "Default personas for simulated panel interviews",
      "properties": {
        "enabled": {"type": "boolean", "default": true},
        "default_personas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "role": {"type": "string"},
              "description": {"type": "string"},
              "perspective": {"type": "string"},
              "weight": {"type": "number", "minimum": 0, "maximum": 1},
              "focus_areas": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "consensus_calculation": {
          "enum": ["weighted_average", "median", "mode_with_outlier_removal"]
        }
      }
    },
    "evidence_weighting": {
      "type": "object",
      "description": "How different evidence types are weighted",
      "properties": {
        "direct_evidence": {"type": "number", "default": 1.0},
        "indirect_evidence": {"type": "number", "default": 0.7},
        "inferred_evidence": {"type": "number", "default": 0.5},
        "validated_external": {"type": "number", "default": 1.2},
        "self_reported_only": {"type": "number", "default": 0.6}
      }
    },
    "time_decay": {
      "type": "object",
      "description": "How to weight evidence age",
      "properties": {
        "enabled": {"type": "boolean", "default": true},
        "half_life_months": {"type": "integer", "default": 24},
        "apply_to": {
          "type": "array",
          "items": {"enum": ["work_history", "education", "skills", "projects"]}
        }
      }
    }
  }
}
