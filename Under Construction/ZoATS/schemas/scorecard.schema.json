{
  "": "https://json-schema.org/draft/2020-12/schema",
  "": "https://va.local/zoats/schemas/scorecard.schema.json",
  "title": "Scorecard",
  "type": "object",
  "required": ["candidate_id","rubric_id","scores","evidence"],
  "properties": {
    "candidate_id": {"type":"string"},
    "rubric_id": {"type":"string"},
    "scores": {"type":"object", "additionalProperties": {"type":"number","minimum":0,"maximum":4}},
    "normalized": {"type":"number","minimum":0,"maximum":1},
    "verdict": {"type":"string", "enum":["advance","hold","reject"]},
    "evidence": {"type":"array", "items": {"":"evidence_item.schema.json"}}
  }
}
