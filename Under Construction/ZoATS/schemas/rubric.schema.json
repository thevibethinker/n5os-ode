{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zoats.careerspan.com/schemas/rubric.schema.json",
  "title": "ZoATS Evaluation Rubric",
  "description": "Schema for job-specific candidate evaluation rubrics",
  "type": "object",
  "required": [
    "version",
    "job_id",
    "job_title",
    "created_at",
    "criteria_groups",
    "scoring_config",
    "thresholds"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "description": "Unique job identifier (slug)",
      "pattern": "^[a-z0-9-]+$"
    },
    "job_title": {
      "type": "string",
      "description": "Human-readable job title"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of rubric creation"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "created_by": {
      "type": "string",
      "description": "Person/entity who created the rubric"
    },
    "meta": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "company": {"type": "string"},
        "department": {"type": "string"},
        "team_size": {"type": "integer"},
        "remote_policy": {"enum": ["onsite", "hybrid", "remote", "flexible"]},
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "criteria_groups": {
      "type": "array",
      "description": "Grouped evaluation criteria",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "weight", "criteria"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "name": {
            "type": "string",
            "description": "Display name for this criteria group"
          },
          "description": {
            "type": "string",
            "description": "What this group evaluates"
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Weight in overall score (all groups must sum to 1.0)"
          },
          "criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "name", "weight", "scoring_method"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9_]+$"
                },
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string",
                  "description": "What excellent looks like for this criterion"
                },
                "weight": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Weight within this criteria group (must sum to 1.0 per group)"
                },
                "scoring_method": {
                  "enum": [
                    "binary",
                    "scale_1_5",
                    "scale_1_10",
                    "percentile",
                    "comparative",
                    "evidence_count"
                  ],
                  "description": "How this criterion is scored"
                },
                "is_dealbreaker": {
                  "type": "boolean",
                  "default": false,
                  "description": "If true, failing this criterion auto-rejects"
                },
                "dealbreaker_threshold": {
                  "type": "number",
                  "description": "Score below which candidate is rejected (if dealbreaker)"
                },
                "evidence_types": {
                  "type": "array",
                  "description": "What evidence validates this criterion",
                  "items": {
                    "enum": [
                      "resume_section",
                      "work_history",
                      "education",
                      "portfolio_link",
                      "github_profile",
                      "linkedin_endorsement",
                      "screening_response",
                      "writing_sample",
                      "code_sample",
                      "case_study",
                      "reference",
                      "news_mention",
                      "published_work"
                    ]
                  }
                },
                "evaluation_prompts": {
                  "type": "array",
                  "description": "AI evaluation instructions for this criterion",
                  "items": {"type": "string"}
                },
                "red_flags": {
                  "type": "array",
                  "description": "Patterns that should lower the score",
                  "items": {"type": "string"}
                },
                "green_flags": {
                  "type": "array",
                  "description": "Patterns that should increase the score",
                  "items": {"type": "string"}
                }
              }
            }
          }
        }
      }
    },
    "scoring_config": {
      "type": "object",
      "required": ["method", "scale"],
      "properties": {
        "method": {
          "enum": ["weighted_average", "rubric_matrix", "comparative_ranking"],
          "description": "Overall scoring methodology"
        },
        "scale": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": {"type": "number"},
            "max": {"type": "number"},
            "unit": {"type": "string", "default": "points"}
          }
        },
        "normalization": {
          "enum": ["none", "z_score", "min_max", "percentile"],
          "default": "none",
          "description": "How to normalize scores across candidates"
        },
        "multi_perspective": {
          "type": "object",
          "description": "Simulated panel interview configuration",
          "properties": {
            "enabled": {"type": "boolean", "default": true},
            "personas": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "string"},
                  "role": {"type": "string"},
                  "description": {"type": "string"},
                  "weight": {"type": "number", "minimum": 0, "maximum": 1}
                }
              }
            }
          }
        }
      }
    },
    "thresholds": {
      "type": "object",
      "required": ["reject", "review", "interview", "finalist"],
      "properties": {
        "reject": {
          "type": "number",
          "description": "Score below this = auto-reject"
        },
        "review": {
          "type": "number",
          "description": "Score below this = manual review needed"
        },
        "interview": {
          "type": "number",
          "description": "Score above this = recommend interview"
        },
        "finalist": {
          "type": "number",
          "description": "Score above this = finalist consideration"
        }
      }
    },
    "authenticity_checks": {
      "type": "object",
      "description": "Configuration for detecting AI-generated content",
      "properties": {
        "enabled": {"type": "boolean", "default": true},
        "ai_generation_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.7,
          "description": "Likelihood above which to flag content"
        },
        "uniqueness_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.15,
          "description": "How much uniqueness affects overall score"
        },
        "specificity_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.15,
          "description": "How much specificity affects overall score"
        }
      }
    },
    "screening_questions": {
      "type": "array",
      "description": "Core questions to ask all candidates",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "question": {"type": "string"},
          "purpose": {"type": "string"},
          "evaluates_criteria": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Criterion IDs this question addresses"
          },
          "expected_response_length": {
            "enum": ["short", "medium", "long"],
            "default": "medium"
          },
          "follow_up_triggers": {
            "type": "array",
            "description": "Conditions that trigger personalized follow-ups",
            "items": {"type": "string"}
          }
        }
      }
    },
    "ultra_signals": {
      "type": "object",
      "description": "Exceptional indicators to surface",
      "properties": {
        "green_flags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "red_flags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "bonus_criteria": {
          "type": "array",
          "description": "Optional attributes that boost score significantly",
          "items": {
            "type": "object",
            "properties": {
              "criterion": {"type": "string"},
              "bonus_points": {"type": "number"},
              "description": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
