  "scoring_scale_definitions": {
    "scale_1_5": {
      "1": "Well below expectations - Major gaps",
      "2": "Below expectations - Significant development needed",
      "3": "Meets expectations - Adequate for role",
      "4": "Exceeds expectations - Strong performer",
      "5": "Far exceeds expectations - Exceptional talent"
    },
    "scale_1_10": {
      "1-2": "Poor - Not qualified",
      "3-4": "Below Average - Significant gaps",
      "5-6": "Average - Meets minimum requirements",
      "7-8": "Above Average - Strong candidate",
      "9-10": "Excellent - Top tier talent"
    },
    "binary": {
      "pass": 1,
      "fail": 0
    },
    "percentile": {
      "description": "Rank against all candidates in pool (0-100)",
      "requires_minimum_candidates": 5
    }
  },
  
  "authenticity_scoring_config": {
    "ai_detection_weight": 0.40,
    "uniqueness_weight": 0.30,
    "specificity_weight": 0.30,
    "ai_detection_threshold": 0.70,
    "uniqueness_comparison": "job_candidates",
    "specificity_metrics": [
      {
        "metric": "concrete_examples",
        "weight": 0.35
      },
      {
        "metric": "unique_details",
        "weight": 0.35
      },
      {
        "metric": "personal_voice",
        "weight": 0.30
      }
    ]
  },
  
