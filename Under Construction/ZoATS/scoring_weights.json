  "cross_reference_validation_weights": {
    "linkedin_match": 0.35,
    "github_validation": 0.25,
    "portfolio_quality": 0.20,
    "news_mentions": 0.10,
    "other_external": 0.10
  },
  
  "normalization_config": {
    "enabled": true,
    "method": "percentile",
    "apply_after_candidates": 5,
    "recalculate_frequency": "per_new_candidate"
